<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ZaarHub — Discover & Support Your Local Community</title>
<meta name="description" content="ZaarHub connects you with local businesses, deals, and events in your city. Discover and support your community.">
<style>
/* ── Reset & Base ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --warm-cream:#FFF8F0;
  --terracotta:#E07A5F;
  --terracotta-dark:#C8654A;
  --terracotta-light:#F4A88A;
  --earthy-green:#3D5A45;
  --earthy-light:#5A7D64;
  --sunshine:#F4B942;
  --deep-navy:#1B2A3B;
  --slate:#2D4059;
  --white:#FFFFFF;
  --off-white:#FDF8F3;
  --light-gray:#F0EBE5;
  --mid-gray:#9B8F87;
  --text:#2C2420;
  --text-secondary:#6B5E56;
  --shadow-sm:0 1px 3px rgba(0,0,0,.08);
  --shadow-md:0 4px 12px rgba(0,0,0,.1);
  --shadow-lg:0 8px 24px rgba(0,0,0,.12);
  --radius-sm:8px;
  --radius-md:12px;
  --radius-lg:16px;
  --radius-xl:20px;
  --font:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
}
body{font-family:var(--font);background:var(--warm-cream);color:var(--text);line-height:1.6;overflow-x:hidden}
a{color:var(--terracotta);text-decoration:none;transition:color .2s}
a:hover{color:var(--terracotta-dark)}
img{max-width:100%;height:auto;display:block}
button{cursor:pointer;font-family:inherit;border:none;background:none}

/* ── Header ── */
header{background:var(--white);border-bottom:1px solid var(--light-gray);position:sticky;top:0;z-index:100}
.header-inner{max-width:1280px;margin:0 auto;padding:0 24px;display:flex;align-items:center;height:68px;gap:20px}
.logo{font-size:1.4rem;font-weight:800;color:var(--deep-navy);display:flex;align-items:center;gap:8px;white-space:nowrap}
.logo span{color:var(--terracotta)}
.logo-icon{width:32px;height:32px;background:var(--terracotta);border-radius:8px;display:flex;align-items:center;justify-content:center;color:white;font-size:1.1rem;font-weight:700}
.city-picker{position:relative;display:flex;align-items:center;gap:6px;padding:8px 14px;background:var(--off-white);border-radius:var(--radius-sm);font-size:.875rem;font-weight:600;color:var(--text);border:1px solid var(--light-gray);cursor:pointer;white-space:nowrap;transition:all .2s}
.city-picker:hover{border-color:var(--terracotta-light);background:var(--white)}
.city-picker .arrow{font-size:.6rem;margin-left:4px;opacity:.6}
.header-search{flex:1;max-width:480px;position:relative}
.header-search input{width:100%;padding:10px 16px 10px 40px;border:1px solid var(--light-gray);border-radius:24px;font-size:.875rem;background:var(--off-white);outline:none;transition:all .2s}
.header-search input:focus{border-color:var(--terracotta-light);background:var(--white);box-shadow:0 0 0 3px rgba(224,122,95,.12)}
.header-search .icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);font-size:.9rem;opacity:.5}
.header-actions{display:flex;gap:10px;align-items:center;margin-left:auto}
.btn{display:inline-flex;align-items:center;justify-content:center;padding:9px 18px;border-radius:24px;font-size:.85rem;font-weight:600;transition:all .2s;gap:6px}
.btn-primary{background:var(--terracotta);color:white}
.btn-primary:hover{background:var(--terracotta-dark);transform:translateY(-1px);box-shadow:var(--shadow-sm)}
.btn-outline{border:1.5px solid var(--light-gray);color:var(--text);background:transparent}
.btn-outline:hover{border-color:var(--terracotta-light);color:var(--terracotta)}
.btn-ghost{color:var(--text-secondary)}
.btn-ghost:hover{color:var(--terracotta)}
.btn-sm{padding:6px 14px;font-size:.8rem}
.auth-badge{width:34px;height:34px;border-radius:50%;background:var(--light-gray);display:flex;align-items:center;justify-content:center;font-size:.9rem;cursor:pointer;transition:all .2s}
.auth-badge:hover{background:var(--terracotta-light);color:white}

/* ── Hero ── */
.hero{max-width:1280px;margin:0 auto;padding:48px 24px 32px;text-align:center}
.hero h1{font-size:clamp(2rem,5vw,3.5rem);font-weight:800;color:var(--deep-navy);line-height:1.15;margin-bottom:12px}
.hero h1 em{font-style:normal;color:var(--terracotta)}
.hero p{font-size:clamp(1rem,2vw,1.2rem);color:var(--text-secondary);max-width:560px;margin:0 auto 28px}
.hero-search{max-width:600px;margin:0 auto 20px;position:relative}
.hero-search input{width:100%;padding:16px 24px 16px 52px;border:2px solid var(--light-gray);border-radius:50px;font-size:1rem;background:var(--white);outline:none;transition:all .3s}
.hero-search input:focus{border-color:var(--terracotta);box-shadow:0 0 0 4px rgba(224,122,95,.15)}
.hero-search .icon{position:absolute;left:20px;top:50%;transform:translateY(-50%);font-size:1.2rem;opacity:.4}
.hero-pills{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:6px}
.pill{display:inline-flex;align-items:center;gap:5px;padding:7px 16px;background:var(--white);border:1.5px solid var(--light-gray);border-radius:20px;font-size:.825rem;font-weight:500;color:var(--text-secondary);transition:all .2s}
.pill:hover{border-color:var(--terracotta-light);color:var(--terracotta);background:var(--off-white);transform:translateY(-1px)}

/* ── Activity Ticker ── */
.ticker{background:var(--earthy-green);color:white;padding:10px 0;overflow:hidden}
.ticker-inner{display:flex;animation:ticker 25s linear infinite;white-space:nowrap;gap:60px;font-size:.85rem}
.ticker-inner span{display:flex;align-items:center;gap:6px;opacity:.9}
.ticker-inner .sep{color:var(--earthy-light)}
@keyframes ticker{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* ── Section Common ── */
section{padding:48px 24px}
.section-inner{max-width:1280px;margin:0 auto}
.section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px}
.section-header h2{font-size:1.5rem;font-weight:700;color:var(--deep-navy)}
.section-header a{font-size:.875rem;font-weight:600;color:var(--terracotta)}
.section-header a:hover{color:var(--terracotta-dark)}

/* ── City Cards Grid ── */
.city-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
.city-card{background:var(--white);border-radius:var(--radius-md);padding:24px;border:1px solid var(--light-gray);transition:all .3s;position:relative;overflow:hidden}
.city-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--terracotta),var(--sunshine));opacity:0;transition:opacity .3s}
.city-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-md)}
.city-card:hover::before{opacity:1}
.city-card h3{font-size:1.15rem;font-weight:700;margin-bottom:4px}
.city-card .count{font-size:.85rem;color:var(--text-secondary)}
.city-card .count strong{color:var(--terracotta)}
.city-card .cta{display:inline-flex;align-items:center;gap:4px;margin-top:12px;font-size:.85rem;font-weight:600;color:var(--terracotta)}

/* ── Deals Carousel ── */
.deal-track{display:flex;gap:16px;overflow-x:auto;padding-bottom:8px;scroll-snap-type:x mandatory;-ms-overflow-style:none;scrollbar-width:none}
.deal-track::-webkit-scrollbar{display:none}
.deal-card{flex:0 0 auto;width:280px;background:var(--white);border-radius:var(--radius-md);border:1px solid var(--light-gray);overflow:hidden;transition:all .3s;scroll-snap-align:start}
.deal-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-md)}
.deal-img{height:140px;background:var(--light-gray);display:flex;align-items:center;justify-content:center;font-size:2rem;color:var(--mid-gray);position:relative}
.deal-img .discount-badge{position:absolute;top:10px;left:10px;background:var(--terracotta);color:white;padding:4px 10px;border-radius:6px;font-size:.75rem;font-weight:700}
.deal-body{padding:14px}
.deal-body .biz-name{font-size:.75rem;color:var(--text-secondary);margin-bottom:2px}
.deal-body h4{font-size:.95rem;font-weight:700;margin-bottom:6px}
.deal-body .price{font-size:.9rem}
.deal-body .price .orig{text-decoration:line-through;color:var(--mid-gray);margin-right:6px}
.deal-body .price .deal{color:var(--terracotta);font-weight:700}

/* ── Events ── */
.event-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px}
.event-card{background:var(--white);border-radius:var(--radius-md);padding:20px;border:1px solid var(--light-gray);display:flex;gap:14px;transition:all .3s}
.event-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-md)}
.event-date{text-align:center;min-width:56px;padding:8px 10px;background:var(--off-white);border-radius:var(--radius-sm)}
.event-date .day{font-size:1.3rem;font-weight:800;color:var(--terracotta);display:block;line-height:1}
.event-date .mon{font-size:.7rem;text-transform:uppercase;color:var(--text-secondary)}
.event-info{flex:1}
.event-info h4{font-size:.95rem;font-weight:700;margin-bottom:3px}
.event-info .meta{font-size:.78rem;color:var(--text-secondary);display:flex;gap:12px;flex-wrap:wrap}
.event-info .meta span{display:flex;align-items:center;gap:3px}

/* ── Community Spotlight ── */
.spotlight{background:var(--deep-navy);color:white;padding:56px 24px}
.spotlight-inner{max-width:1280px;margin:0 auto;display:flex;gap:40px;align-items:center;flex-wrap:wrap}
.spotlight-content{flex:1;min-width:280px}
.spotlight-content .label{font-size:.8rem;text-transform:uppercase;letter-spacing:1px;color:var(--sunshine);margin-bottom:8px}
.spotlight-content h2{font-size:2rem;font-weight:700;margin-bottom:12px}
.spotlight-content p{color:rgba(255,255,255,.7);line-height:1.7;margin-bottom:16px}
.spotlight-content .btn{background:var(--sunshine);color:var(--deep-navy)}
.spotlight-content .btn:hover{background:var(--terracotta-light);color:white}
.spotlight-img{width:320px;height:240px;background:var(--slate);border-radius:var(--radius-lg);display:flex;align-items:center;justify-content:center;font-size:3rem;color:var(--mid-gray)}

/* ── Business Owner CTA ── */
.owner-cta{text-align:center;padding:64px 24px;background:var(--off-white)}
.owner-cta h2{font-size:1.8rem;font-weight:700;margin-bottom:8px}
.owner-cta p{color:var(--text-secondary);max-width:500px;margin:0 auto 24px}
.owner-cta .btn{padding:14px 32px;font-size:1rem}

/* ── Footer ── */
footer{background:var(--deep-navy);color:rgba(255,255,255,.7);padding:48px 24px 32px}
.footer-inner{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:32px}
footer h4{color:white;font-size:.9rem;margin-bottom:12px}
footer a{display:block;color:rgba(255,255,255,.6);font-size:.85rem;margin-bottom:6px;transition:color .2s}
footer a:hover{color:var(--terracotta-light)}
.footer-bottom{border-top:1px solid rgba(255,255,255,.1);margin-top:32px;padding-top:24px;text-align:center;font-size:.8rem}

/* ── Loading & States ── */
.loading{display:flex;align-items:center;justify-content:center;padding:40px;color:var(--mid-gray);gap:8px}
.loading .spinner{width:20px;height:20px;border:2.5px solid var(--light-gray);border-top-color:var(--terracotta);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.empty-state{text-align:center;padding:40px;color:var(--mid-gray);font-size:.9rem}
.error-state{text-align:center;padding:40px;color:var(--terracotta);font-size:.9rem}

/* ── Responsive ── */
@media(max-width:768px){
  .header-inner{gap:10px}
  .header-search{display:none}
  .logo{font-size:1.1rem}
  .btn span.label{display:none}
  .city-grid{grid-template-columns:1fr 1fr}
  .spotlight-inner{flex-direction:column;text-align:center}
  .spotlight-img{width:100%;max-width:360px;margin:0 auto}
  section{padding:32px 16px}
}
@media(max-width:480px){
  .city-grid{grid-template-columns:1fr}
  .hero h1{font-size:1.7rem}
  .deal-card{width:240px}
  .event-card{flex-direction:column}
}
</style>
</head>
<body>

<!-- ═══ Ticker ═══ -->
<div class="ticker" id="ticker">
  <div class="ticker-inner" id="tickerInner">
    <span>👋 Welcome to ZaarHub — Discover local businesses in your community</span>
    <span class="sep">•</span>
    <span>⭐ Loading activity...</span>
    <span class="sep">•</span>
  </div>
</div>

<!-- ═══ Header ═══ -->
<header>
  <div class="header-inner">
    <a href="/" class="logo">
      <div class="logo-icon">Z</div>
      Zaar<span>Hub</span>
    </a>
    <div class="city-picker" onclick="window.location.href='/'">
      📍 All Cities <span class="arrow">▾</span>
    </div>
    <div class="header-search">
      <span class="icon">🔍</span>
      <input type="text" placeholder="Search businesses, services, or categories..." id="globalSearch" onkeydown="if(event.key==='Enter') doSearch(this.value)">
    </div>
    <div class="header-actions">
      <a href="/grow" class="btn btn-outline btn-sm"><span class="label">For Businesses</span> 💼</a>
      <a href="/visitor/login" class="btn btn-ghost btn-sm">Sign In</a>
      <a href="/visitor/register" class="btn btn-primary btn-sm">Join</a>
    </div>
  </div>
</header>

<!-- ═══ Hero ═══ -->
<section class="hero">
  <div class="section-inner">
    <h1>Discover &amp; Support <em>Your Local Community</em></h1>
    <p>Find the best local businesses, exclusive deals, and community events in your city. ZaarHub connects you with what makes your neighborhood great.</p>
    <div class="hero-search">
      <span class="icon">🔍</span>
      <input type="text" placeholder="Search for tacos, plumbers, coffee shops..." id="heroSearch" onkeydown="if(event.key==='Enter') doSearch(this.value)">
    </div>
    <div class="hero-pills" id="categoryPills">
      <span class="loading"><span class="spinner"></span> Loading categories...</span>
    </div>
  </div>
</section>

<!-- ═══ Cities Grid ═══ -->
<section>
  <div class="section-inner">
    <div class="section-header">
      <h2>🌆 Explore Cities</h2>
    </div>
    <div class="city-grid" id="cityGrid">
      <div class="loading"><span class="spinner"></span> Loading cities...</div>
    </div>
  </div>
</section>

<!-- ═══ Hot Deals ═══ -->
<section style="background:var(--off-white)">
  <div class="section-inner">
    <div class="section-header">
      <h2>🔥 Hot Local Deals</h2>
    </div>
    <div class="deal-track" id="dealTrack">
      <div class="loading"><span class="spinner"></span> Loading deals...</div>
    </div>
  </div>
</section>

<!-- ═══ Upcoming Events ═══ -->
<section>
  <div class="section-inner">
    <div class="section-header">
      <h2>📅 Community Events</h2>
    </div>
    <div class="event-grid" id="eventGrid">
      <div class="loading"><span class="spinner"></span> Loading events...</div>
    </div>
  </div>
</section>

<!-- ═══ Community Spotlight ═══ -->
<section class="spotlight">
  <div class="spotlight-inner">
    <div class="spotlight-content">
      <div class="label">Community Spotlight</div>
      <h2>Meet the People Behind Your Local Businesses</h2>
      <p>Every business has a story. ZaarHub helps you discover the founders, owners, and families that make your community unique. From family-owned restaurants to local craftspeople — get to know who's behind the counter.</p>
      <a href="/claim" class="btn">Claim Your Business 🏪</a>
    </div>
    <div class="spotlight-img">🏪</div>
  </div>
</section>

<!-- ═══ Owner CTA ═══ -->
<section class="owner-cta">
  <div class="section-inner">
    <h2>Are You a Local Business Owner?</h2>
    <p>Claim your free listing, manage your profile, post deals, and connect with your community. Grow your local presence with ZaarHub.</p>
    <a href="/claim" class="btn btn-primary">Claim Your Free Listing →</a>
  </div>
</section>

<!-- ═══ Footer ═══ -->
<footer>
  <div class="footer-inner">
    <div>
      <h4>ZaarHub</h4>
      <a href="/">Home</a>
      <a href="/cities">All Cities</a>
      <a href="/grow">For Businesses</a>
      <a href="/about">About</a>
    </div>
    <div>
      <h4>Explore</h4>
      <a href="/deals">Local Deals &amp; Perks</a>
      <a href="/events">Community Events</a>
      <a href="/categories">Categories</a>
    </div>
    <div>
      <h4>For Businesses</h4>
      <a href="/claim">Claim Your Listing</a>
      <a href="/portal/business/dashboard">Business Dashboard</a>
      <a href="/grow">Pricing &amp; Plans</a>
    </div>
    <div>
      <h4>Support</h4>
      <a href="/legal-terms">Terms &amp; Privacy</a>
      <a href="/contact">Contact Us</a>
    </div>
  </div>
  <div class="footer-bottom">© 2026 ZaarHub — Powered by Multi-Directory</div>
</footer>

<script>
// ── Utils ──
const API = '/api/v1/zaarhub';

function html(str, ...vals) {
  return str.reduce((r, s, i) => r + escapeHtml(vals[i-1]) + s);
}
function escapeHtml(s) {
  if (s == null) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── Load Category Pills ──
async function loadCategories() {
  try {
    const res = await fetch(`${API}/homepage`);
    const data = await res.json();
    const pills = document.getElementById('categoryPills');
    if (!data.category_pills || data.category_pills.length === 0) {
      pills.innerHTML = defaultPills();
      return;
    }
    pills.innerHTML = data.category_pills.map(c =>
      `<a href="/search?category=${c.slug}" class="pill">${iconFor(c.name)} ${c.name}</a>`
    ).join('');
  } catch(e) {
    document.getElementById('categoryPills').innerHTML = defaultPills();
  }
}
function defaultPills() {
  return [
    { n:'Coffee ☕', s:'coffee' }, { n:'Restaurants 🍔', s:'restaurant' },
    { n:'Services 🔧', s:'services' }, { n:'Fitness 🏋️', s:'fitness' },
    { n:'Events 🎟️', s:'events' }, { n:'Shopping 🛍️', s:'shopping' },
  ].map(p => `<a href="/search?category=${p.s}" class="pill">${p.n}</a>`).join('');
}
function iconFor(name) {
  const icons = { restaurant:'🍔', 'fitness studio':'🏋️', dentist:'🦷', 'real estate agent':'🏠',
    'day spa':'💆', 'personal injury lawyer':'⚖️', coffee:'☕', services:'🔧',
    events:'🎟️', shopping:'🛍️', fitness:'🏋️' };
  return icons[name.toLowerCase()] || '📍';
}

// ── Load Cities ──
async function loadCities() {
  try {
    const res = await fetch(`${API}/cities`);
    const cities = await res.json();
    const grid = document.getElementById('cityGrid');
    if (!cities || cities.length === 0) {
      grid.innerHTML = '<div class="empty-state">No cities available yet. Check back soon!</div>';
      return;
    }
    grid.innerHTML = cities.map(c => `
      <a href="/cities/${c.slug}" class="city-card">
        <h3>${escapeHtml(c.name)}</h3>
        <div class="count"><strong>${c.business_count}</strong> local spots</div>
        ${c.description ? `<p style="font-size:.8rem;color:var(--text-secondary);margin-top:6px">${escapeHtml(c.description)}</p>` : ''}
        <div class="cta">Explore →</div>
      </a>
    `).join('');
  } catch(e) {
    document.getElementById('cityGrid').innerHTML = '<div class="error-state">⚠️ Could not load cities. Please try again.</div>';
  }
}

// ── Load Deals ──
async function loadDeals() {
  try {
    const res = await fetch(`${API}/homepage`);
    const data = await res.json();
    const track = document.getElementById('dealTrack');
    if (!data.featured_deals || data.featured_deals.length === 0) {
      track.innerHTML = '<div class="empty-state">No featured deals right now. Check back soon!</div>';
      return;
    }
    track.innerHTML = data.featured_deals.map(d => `
      <a href="/cities/${d.directory_slug}" class="deal-card">
        <div class="deal-img">
          ${d.discount_percent ? `<span class="discount-badge">-${d.discount_percent}%</span>` : ''}
          🏪
        </div>
        <div class="deal-body">
          <div class="biz-name">${escapeHtml(d.business_name)}</div>
          <h4>${escapeHtml(d.title)}</h4>
          <div class="price">
            ${d.original_price ? `<span class="orig">${escapeHtml(d.original_price)}</span>` : ''}
            ${d.deal_price ? `<span class="deal">${escapeHtml(d.deal_price)}</span>` : ''}
          </div>
        </div>
      </a>
    `).join('');
  } catch(e) {
    document.getElementById('dealTrack').innerHTML = '<div class="empty-state">Deals loading...</div>';
  }
}

// ── Load Events ──
async function loadEvents() {
  try {
    const res = await fetch(`${API}/homepage`);
    const data = await res.json();
    const grid = document.getElementById('eventGrid');
    if (!data.upcoming_events || data.upcoming_events.length === 0) {
      grid.innerHTML = '<div class="empty-state">No upcoming events. Check back soon!</div>';
      return;
    }
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    grid.innerHTML = data.upcoming_events.map(e => {
      const d = e.event_date ? new Date(e.event_date) : null;
      const day = d ? d.getDate() : '?';
      const mon = d ? months[d.getMonth()] : '';
      return `
        <div class="event-card">
          <div class="event-date">
            <span class="day">${day}</span>
            <span class="mon">${mon}</span>
          </div>
          <div class="event-info">
            <h4>${escapeHtml(e.title)}</h4>
            <div class="meta">
              ${e.location ? `<span>📍 ${escapeHtml(e.location)}</span>` : ''}
              ${e.rsvp_count != null ? `<span>👥 ${e.rsvp_count} attending</span>` : ''}
            </div>
            ${e.description ? `<p style="font-size:.8rem;color:var(--text-secondary);margin-top:6px">${escapeHtml(e.description)}</p>` : ''}
          </div>
        </div>
      `;
    }).join('');
  } catch(e) {
    document.getElementById('eventGrid').innerHTML = '<div class="empty-state">Events loading...</div>';
  }
}

// ── Load Activity Ticker ──
async function loadTicker() {
  try {
    const res = await fetch(`${API}/activity`);
    const items = await res.json();
    const inner = document.getElementById('tickerInner');
    if (!items || items.length === 0) return;
    const tickerItems = items.slice(0, 8).map(i =>
      `<span>${escapeHtml(i.message)}</span><span class="sep">•</span>`
    ).join('');
    inner.innerHTML = tickerItems + tickerItems; // double for seamless loop
  } catch(e) {
    // keep default ticker text
  }
}

// ── Search ──
function doSearch(q) {
  if (!q || !q.trim()) return;
  window.location.href = `/search?q=${encodeURIComponent(q.trim())}`;
}

// ── Stats Counter Animation ──
function animateCounters() {
  document.querySelectorAll('.stat-num').forEach(el => {
    const target = parseInt(el.dataset.count);
    if (!target) return;
    let current = 0;
    const step = Math.ceil(target / 40);
    const interval = setInterval(() => {
      current = Math.min(current + step, target);
      el.textContent = current.toLocaleString();
      if (current >= target) clearInterval(interval);
    }, 30);
  });
}

// ── Init ──
document.addEventListener('DOMContentLoaded', () => {
  loadCategories();
  loadCities();
  loadDeals();
  loadEvents();
  loadTicker();
});
</script>
</body>
</html>
