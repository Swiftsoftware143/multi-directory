<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Multi-Directory</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--teal:#0d9488;--teal-light:#14b8a6;--teal-bg:#f0fdfa;--bg:#f8fafc;--card:#fff;--text:#1e293b;--text-secondary:#64748b;--border:#e2e8f0;--sidebar:#0f172a;--sidebar-text:#94a3b8;--sidebar-active:#14b8a6;--danger:#ef4444;--danger-hover:#dc2626;--success:#22c55e;--warning:#f59e0b}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex}
a{color:var(--teal);text-decoration:none}a:hover{text-decoration:underline}
.login-container{display:flex;align-items:center;justify-content:center;min-height:100vh;background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);width:100%}
.login-card{background:var(--card);border-radius:16px;padding:40px;width:400px;max-width:90vw;box-shadow:0 25px 50px -12px rgba(0,0,0,.4)}
.login-card h1{font-size:1.75rem;color:var(--teal);text-align:center;margin-bottom:4px}
.login-card .tagline{text-align:center;color:var(--text-secondary);font-size:.9rem;margin-bottom:28px}
.login-card .error{background:#fef2f2;color:#dc2626;padding:10px 14px;border-radius:8px;font-size:.85rem;margin-bottom:16px;display:none}
.form-group{margin-bottom:16px}
.form-group label{display:block;font-size:.85rem;font-weight:600;color:var(--text);margin-bottom:4px}
.form-group input,.form-group textarea,.form-group select{width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-size:.9rem;outline:none;transition:border-color .2s;font-family:inherit}
.form-group input:focus,.form-group textarea:focus,.form-group select:focus{border-color:var(--teal);box-shadow:0 0 0 3px rgba(13,148,136,.15)}
.btn{display:inline-flex;align-items:center;justify-content:center;padding:10px 20px;border-radius:8px;font-size:.9rem;font-weight:600;cursor:pointer;border:none;transition:all .2s;gap:6px}
.btn-primary{background:var(--teal);color:#fff}
.btn-primary:hover{background:#0f766e}
.btn-secondary{background:#e2e8f0;color:var(--text);border:1px solid var(--border)}
.btn-secondary:hover{background:#cbd5e1}
.btn-danger{background:var(--danger);color:#fff}
.btn-danger:hover{background:var(--danger-hover)}
.btn-sm{padding:6px 12px;font-size:.8rem}
.btn-full{width:100%}
.btn:disabled{opacity:.6;cursor:not-allowed}
.sidebar{width:260px;min-height:100vh;background:var(--sidebar);position:fixed;top:0;left:0;display:flex;flex-direction:column;z-index:100}
.sidebar-brand{padding:24px 20px 16px;border-bottom:1px solid #1e293b}
.sidebar-brand h2{color:var(--teal-light);font-size:1.1rem;letter-spacing:.5px}
.sidebar-brand p{color:var(--sidebar-text);font-size:.75rem;margin-top:2px}
.sidebar-nav{flex:1;padding:12px 0}
.sidebar-nav a{display:flex;align-items:center;gap:10px;padding:10px 20px;color:var(--sidebar-text);font-size:.85rem;transition:all .2s;border-left:3px solid transparent;cursor:pointer}
.sidebar-nav a:hover,.sidebar-nav a.active{color:#fff;background:rgba(20,184,166,.1);border-left-color:var(--teal-light)}
.sidebar-nav a .icon{font-size:1.1rem;width:22px;text-align:center}
.sidebar-footer{padding:16px 20px;border-top:1px solid #1e293b;font-size:.8rem;color:var(--sidebar-text)}
.sidebar-footer .user-email{color:#fff;font-weight:600;margin-bottom:4px}
.sidebar-footer a{color:var(--sidebar-text);cursor:pointer}
.sidebar-footer a:hover{color:var(--danger)}
.main{margin-left:260px;flex:1;padding:0;min-height:100vh}
.main-header{display:flex;align-items:center;justify-content:space-between;padding:20px 32px;border-bottom:1px solid var(--border);background:var(--card);position:sticky;top:0;z-index:50}
.main-header h1{font-size:1.4rem;font-weight:700}
.main-header-actions{display:flex;gap:8px;align-items:center}
.main-content{padding:24px 32px}
.card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px}
.card:hover{box-shadow:0 4px 12px rgba(0,0,0,.06)}
.card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
.stat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:24px}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:24px;text-align:center}
.stat-card .num{font-size:2.25rem;font-weight:800;color:var(--teal);display:block}
.stat-card .label{font-size:.85rem;color:var(--text-secondary);margin-top:4px}
.stat-card .icon{font-size:1.5rem;margin-bottom:8px}
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse}
th,td{text-align:left;padding:10px 14px;border-bottom:1px solid var(--border);font-size:.85rem}
th{font-weight:600;color:var(--text-secondary);background:#f8fafc;font-size:.8rem;text-transform:uppercase;letter-spacing:.5px}
tr:hover td{background:#f8fafc}
.modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.5);z-index:200;display:flex;align-items:center;justify-content:center;padding:20px}
.modal{background:var(--card);border-radius:16px;width:520px;max-width:100%;max-height:90vh;overflow-y:auto;padding:28px}
.modal h2{font-size:1.2rem;margin-bottom:20px;color:var(--text)}
.modal-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:20px}
.toast-container{position:fixed;top:20px;right:20px;z-index:300;display:flex;flex-direction:column;gap:8px}
.toast{padding:12px 20px;border-radius:10px;font-size:.85rem;font-weight:500;box-shadow:0 10px 30px rgba(0,0,0,.15);animation:slideIn .3s ease;max-width:360px}
.toast.success{background:#14532d;color:#bbf7d0}
.toast.error{background:#7f1d1d;color:#fca5a5}
.toast.info{background:#1e3a5f;color:#bfdbfe}
.search-box{display:flex;gap:8px;margin-bottom:20px}
.search-box input{flex:1;padding:12px 16px;border:1px solid var(--border);border-radius:10px;font-size:.95rem;outline:none}
.search-box input:focus{border-color:var(--teal);box-shadow:0 0 0 3px rgba(13,148,136,.15)}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:.75rem;font-weight:600}
.badge.active{background:#14532d;color:#bbf7d0}
.badge.inactive{background:#7f1d1d;color:#fca5a5}
.badge.category{background:#1e3a5f;color:#bfdbfe}
.badge.key-active{background:#14532d;color:#bbf7d0}
.badge.key-revoked{background:#7f1d1d;color:#fca5a5}
input[type="color"].tc-color::-webkit-color-swatch-wrapper{padding:0}
input[type="color"].tc-color::-webkit-color-swatch{border:none;border-radius:4px}

.walkthrough-overlay{position:fixed;top:0;left:0;width:100%;height:100%;z-index:400;display:none;align-items:center;justify-content:center}
.walkthrough-bg{position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.6);-webkit-backdrop-filter:blur(4px);backdrop-filter:blur(4px)}
.walkthrough-card{position:relative;background:var(--card);border-radius:20px;padding:36px 32px 28px;max-width:480px;width:90%;text-align:center;box-shadow:0 30px 60px rgba(0,0,0,.4);animation:fadeIn .3s ease}
.walkthrough-icon{width:64px;height:64px;border-radius:50%;background:var(--teal-bg);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:1.75rem}
.walkthrough-card h3{font-size:1.2rem;color:var(--teal);margin-bottom:12px}
.walkthrough-card p{font-size:.9rem;color:var(--text-secondary);line-height:1.6;margin-bottom:24px}
.walkthrough-actions{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.walkthrough-dots{display:flex;justify-content:center;gap:6px;margin-bottom:20px}
.walkthrough-dots span{width:8px;height:8px;border-radius:50%;background:var(--border);transition:all .2s}
.walkthrough-dots span.active{background:var(--teal);width:24px;border-radius:4px}
.help-icon{position:fixed;bottom:24px;right:24px;width:48px;height:48px;border-radius:50%;background:var(--teal);color:#fff;font-size:1.3rem;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 16px rgba(13,148,136,.4);z-index:150;border:none;transition:transform .2s}
.help-icon:hover{transform:scale(1.1)}
@keyframes slideIn{from{opacity:0;transform:translateX(100%)}to{opacity:1;transform:translateX(0)}}
@keyframes fadeIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}
.spinner{width:20px;height:20px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear;display:inline-block}
.spinner-teal{width:32px;height:32px;border:3px solid rgba(13,148,136,.2);border-top-color:var(--teal);border-radius:50%;animation:spin .6s linear;display:inline-block}
.empty-state{text-align:center;padding:40px 20px;color:var(--text-secondary)}
.empty-state .icon{font-size:3rem;margin-bottom:12px;opacity:.4}
.empty-state h3{font-size:1.1rem;margin-bottom:4px;color:var(--text)}
.empty-state p{font-size:.85rem}
.flex{display:flex;gap:6px;flex-wrap:wrap}
.mt-2{margin-top:8px}
.mb-2{margin-bottom:8px}
.copy-key{font-family:monospace;font-size:.8rem;background:#f1f5f9;padding:2px 6px;border-radius:4px;cursor:pointer}
.copy-key:hover{background:#e2e8f0}
@media(max-width:768px){
.sidebar{width:0;overflow:hidden}
.main{margin-left:0}
.card-grid{grid-template-columns:1fr}
.stat-grid{grid-template-columns:1fr 1fr}
.main-content{padding:16px}
.main-header{padding:16px;flex-wrap:wrap;gap:8px}
}
</style>
</head>
<body>
<div id="app"></div>
<div class="toast-container" id="toastContainer"></div>
<div class="walkthrough-overlay" id="walkthroughOverlay">
<div class="walkthrough-bg" onclick="closeWalkthrough()"></div>
<div class="walkthrough-card">
<div class="walkthrough-dots" id="walkthroughDots"></div>
<div class="walkthrough-icon" id="walkthroughIcon"></div>
<h3 id="walkthroughTitle">Welcome!</h3>
<p id="walkthroughText"></p>
<div class="walkthrough-actions">
<button class="btn btn-primary" onclick="dismissWalkthrough()">Got it!</button>
<button class="btn btn-secondary" onclick="closeWalkthrough()">Remind Later</button>
</div>
</div>
</div>
<button class="help-icon" id="helpIcon" onclick="showWalkthrough(currentPage)" style="display:none;" title="Help">?</button>
<script>
(function(){
var token=localStorage.getItem("ws_dir_token")||"";
var user=JSON.parse(localStorage.getItem("ws_dir_user")||"null");
var CP=location.hash.replace("#","")||"dashboard";

var g_sync=[];
async function loadBlog(){var el=document.getElementById("pageContent"),pa=document.getElementById("pageActions");pa.innerHTML='<button class="btn btn-primary btn-sm" onclick="showBlogModal()">+ New Post</button>';el.innerHTML='<div style="text-align:center;padding:40px"><span class="spinner-teal"></span></div>';try{var posts=await g("/api/v1/blog-posts");if(!posts.length){el.innerHTML='<div class="empty-state"><div class="icon">\ud83d\udcdd</div><h3>No Blog Posts Yet</h3><p>Create blog posts for SEO. Each post appears on the directory landing page.</p></div>';return;}var h='<div class="card-grid">';for(var i=0;i<posts.length;i++){var p=posts[i];h+='<div class="card" style="position:relative;overflow:hidden"><div style="font-size:.75rem;color:var(--text-secondary);margin-bottom:4px">'+esc(p.directory_name||p.directory_id||"")+' <span style="color:var(--border)">|</span> '+(p.published?'<span class="badge active">Published</span>':'<span class="badge inactive">Draft</span>')+'</div><h4 style="font-size:1rem;margin-bottom:6px;color:var(--text)">'+esc(p.title)+'</h4><p style="font-size:.8rem;color:var(--text-secondary);margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">'+esc((p.excerpt||p.content||"").substring(0,200))+'</p><div style="font-size:.75rem;color:var(--text-secondary)">'+(p.slug?'<code style="background:#f1f5f9;padding:1px 5px;border-radius:3px">/'+esc(p.slug)+'</code> ':'')+'<span>Updated: '+(p.updated_at||p.created_at||"").substring(0,10)+'</span></div><div class="flex" style="margin-top:10px"><button class="btn btn-sm btn-secondary" onclick="editBlog('+p.id+')">Edit</button><button class="btn btn-sm btn-danger" onclick="deleteBlog('+p.id+')">Delete</button></div></div>';}h+='</div>';el.innerHTML=h;}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">\u26a0\ufe0f</div><h3>Error</h3><p>'+esc(e.message)+"</p></div>";}}
function showBlogModal(pid){var isEdit=!!pid;var ov=document.createElement("div");ov.className="modal-overlay";ov.id="blogModal";var dirOpts="";var dirs=g_sync;if(!dirs.length){dirOpts='<option value="">No directories found</option>';}else{for(var i=0;i<dirs.length;i++){dirOpts+='<option value="'+dirs[i].id+'">'+esc(dirs[i].name)+'</option>';}}var html='<div class="modal" style="width:600px"><h2>'+(isEdit?"Edit Blog Post":"New Blog Post")+'</h2><div class="form-group"><label>Title *</label><input id="bpTitle" placeholder="Post title"></div><div class="form-group"><label>Slug</label><input id="bpSlug" placeholder="auto-generated-from-title"><div style="font-size:.75rem;color:var(--text-secondary);margin-top:2px">URL path for this post. Leave blank to auto-generate.</div></div><div class="form-group"><label>Directory *</label><select id="bpDir">'+dirOpts+'</select></div><div class="form-group"><label>Excerpt (SEO snippet)</label><textarea id="bpExcerpt" rows="2" placeholder="Brief summary for search results"></textarea></div><div class="form-group"><label>Content * (HTML supported)</label><textarea id="bpContent" rows="8" placeholder="Full blog post content..."></textarea></div><div class="form-group"><label><input type="checkbox" id="bpPublished" checked> Published</label></div><div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal('blogModal')">Cancel</button><button class="btn btn-primary" id="bpSaveBtn" onclick="saveBlog('+(isEdit?pid:"null")+')">Save Post</button></div></div>';ov.innerHTML=html;document.body.appendChild(ov);if(isEdit){fetchBlogForEdit(pid);}}
async function fetchBlogForEdit(pid){try{var p=await g("/api/v1/blog-posts/"+pid);document.getElementById("bpTitle").value=p.title||"";document.getElementById("bpSlug").value=p.slug||"";document.getElementById("bpExcerpt").value=p.excerpt||"";document.getElementById("bpContent").value=p.content||"";document.getElementById("bpPublished").checked=p.published!==false;if(p.directory_id)document.getElementById("bpDir").value=p.directory_id;}catch(e){toast("Failed to load post: "+e.message,"error");}}
async function saveBlog(pid){var title=document.getElementById("bpTitle").value.trim();var dir=document.getElementById("bpDir").value;var content=document.getElementById("bpContent").value.trim();if(!title||!dir||!content){toast("Title, directory, and content are required","error");return;}var body={title:title,slug:document.getElementById("bpSlug").value.trim()||null,excerpt:document.getElementById("bpExcerpt").value.trim()||null,content:content,directory_id:dir,published:document.getElementById("bpPublished").checked};try{if(pid){await pu("/api/v1/blog-posts/"+pid,body);}else{await po("/api/v1/blog-posts",body);}toast("Post saved!");closeModal("blogModal");loadBlog();}catch(e){toast(e.message,"error");}}
async function editBlog(pid){showBlogModal(pid);}
async function deleteBlog(pid){if(!confirm("Delete this blog post?"))return;try{await dl("/api/v1/blog-posts/"+pid);toast("Post deleted");loadBlog();}catch(e){toast(e.message,"error");}}
async function loadLegals(){var el=document.getElementById("pageContent"),pa=document.getElementById("pageActions");pa.innerHTML='<button class="btn btn-primary btn-sm" onclick="showLegalModal()">+ New Page</button>';el.innerHTML='<div style="text-align:center;padding:40px"><span class="spinner-teal"></span></div>';try{var pages=await g("/api/v1/legal-pages");if(!pages.length){el.innerHTML='<div class="empty-state"><div class="icon">\u2696\ufe0f</div><h3>No Legal Pages Yet</h3><p>Create legal pages like Privacy Policy, Terms of Service, DMCA, Disclaimer. They appear in the footer of your directory landing pages.</p></div>';return;}var h='<div class="card-grid">';for(var i=0;i<pages.length;i++){var pg=pages[i];h+='<div class="card"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px"><h4 style="font-size:1rem">'+esc(pg.title)+'</h4><span class="badge '+(pg.published===false?"inactive":"active")+'">'+(pg.published===false?"Draft":"Published")+'</span></div><div style="font-size:.75rem;color:var(--text-secondary);margin-bottom:8px"><span>Type: '+esc(pg.page_type||"custom")+'</span>'+(pg.is_global?' <span style="color:var(--teal)">\ud83c\udf10 Shared across all directories</span>':'')+'</div><p style="font-size:.8rem;color:var(--text-secondary)">'+esc((pg.content||"").substring(0,200))+'</p><div class="flex" style="margin-top:10px"><button class="btn btn-sm btn-secondary" onclick="editLegal('+pg.id+')">Edit</button><button class="btn btn-sm btn-danger" onclick="deleteLegal('+pg.id+')">Delete</button></div></div>';}h+='</div>';el.innerHTML=h;}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">\u26a0\ufe0f</div><h3>Error</h3><p>'+esc(e.message)+"</p></div>";}}
function showLegalModal(pid){var isEdit=!!pid;var ov=document.createElement("div");ov.className="modal-overlay";ov.id="legalModal";var html='<div class="modal" style="width:600px"><h2>'+(isEdit?"Edit Legal Page":"New Legal Page")+'</h2><div class="form-group"><label>Page Title *</label><input id="lgTitle" placeholder="e.g. Privacy Policy"></div><div class="form-group"><label>Page Type</label><select id="lgType"><option value="privacy">Privacy Policy</option><option value="terms">Terms of Service</option><option value="dmca">DMCA</option><option value="disclaimer">Disclaimer</option><option value="refund">Refund Policy</option><option value="cookies">Cookie Policy</option><option value="eula">EULA</option><option value="custom">Custom</option></select></div><div class="form-group"><label><input type="checkbox" id="lgGlobal"> Shared across all connected directories</label><div style="font-size:.75rem;color:var(--text-secondary);margin-top:2px">If checked, this page appears in the footer of ALL directories in the network (same legal pages for sister cities).</div></div><div class="form-group"><label>Content *</label><textarea id="lgContent" rows="10" placeholder="Full legal text. HTML supported."></textarea></div><div class="form-group"><label><input type="checkbox" id="lgPublished" checked> Published (visible in footer)</label></div><div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal('legalModal')">Cancel</button><button class="btn btn-primary" id="lgSaveBtn" onclick="saveLegal('+(isEdit?pid:"null")+')">Save Page</button></div></div>';ov.innerHTML=html;document.body.appendChild(ov);if(isEdit){fetchLegalForEdit(pid);}}
async function fetchLegalForEdit(pid){try{var p=await g("/api/v1/legal-pages/"+pid);document.getElementById("lgTitle").value=p.title||"";document.getElementById("lgType").value=p.page_type||"custom";document.getElementById("lgContent").value=p.content||"";document.getElementById("lgPublished").checked=p.published!==false;document.getElementById("lgGlobal").checked=p.is_global===true;}catch(e){toast("Failed to load page: "+e.message,"error");}}
async function saveLegal(pid){var title=document.getElementById("lgTitle").value.trim();var content=document.getElementById("lgContent").value.trim();if(!title||!content){toast("Title and content are required","error");return;}var body={title:title,page_type:document.getElementById("lgType").value,content:content,published:document.getElementById("lgPublished").checked,is_global:document.getElementById("lgGlobal").checked};try{if(pid){await pu("/api/v1/legal-pages/"+pid,body);}else{await po("/api/v1/legal-pages",body);}toast("Legal page saved!");closeModal("legalModal");loadLegals();}catch(e){toast(e.message,"error");}}
async function editLegal(pid){showLegalModal(pid);}
async function deleteLegal(pid){if(!confirm("Delete this legal page?"))return;try{await dl("/api/v1/legal-pages/"+pid);toast("Page deleted");loadLegals();}catch(e){toast(e.message,"error");}}

var DLS=[];
async function loadDeals(){var el=document.getElementById("pageContent"),pa=document.getElementById("pageActions");pa.innerHTML='<button class="btn btn-primary btn-sm" onclick="showDealModal(null)">+ New Deal</button>';el.innerHTML='<div style="text-align:center;padding:40px"><span class="spinner-teal"></span></div>';try{var deals=await g("/api/v1/deals");DLS=deals;if(!deals.length){el.innerHTML='<div class="empty-state"><div class="icon">\U0001f39f\ufe0f</div><h3>No Deals Yet</h3><p>Click "New Deal" to create your first deal or coupon. Deals appear on directory landing pages and business profiles.</p></div>';return;}var h='<div class="card-grid">';for(var i=0;i<deals.length;i++){var d=deals[i];var pct=d.discount_percent?" -"+d.discount_percent+"%":"";var dp=d.deal_price?"$"+d.deal_price:"";var op=d.original_price?" <s>$"+d.original_price+"</s>":"";h+='<div class="card"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px"><h4 style="font-size:1rem;color:var(--teal)">'+esc(d.title)+'</h4><span class="badge '+(d.status==="active"?"active":"inactive")+'">'+esc(d.status||"unknown")+'</span></div><div style="font-size:.85rem;margin-bottom:6px">'+dp+op+pct+'</div><div style="font-size:.75rem;color:var(--text-secondary);margin-bottom:8px"><span>Redeemed: '+(d.redemption_count||0)+'</span>'+(d.redemption_limit?' <span>| Limit: '+d.redemption_limit+'</span>':'')+(d.featured?' <span class="badge active">Featured</span>':'')+'</div><div class="flex"><button class="btn btn-sm btn-secondary" onclick="editDeal('+d.id+')">Edit</button><button class="btn btn-sm btn-secondary" onclick="claimDeal('+d.id+')">Claim</button><button class="btn btn-sm btn-danger" onclick="deleteDeal('+d.id+')">Delete</button></div></div>';}el.innerHTML=h+'</div>';}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">\u26a0\ufe0f</div><h3>Error</h3><p>'+esc(e.message)+"</p></div>";}}
function showDealModal(did){var isEdit=!!did;var ov=document.createElement("div");ov.className="modal-overlay";ov.id="dealModal";var dirOpts="";var dirs=g_sync;if(!dirs.length){dirOpts='<option value="">No directories</option>';}else{for(var i=0;i<dirs.length;i++){dirOpts+='<option value="'+dirs[i].id+'">'+esc(dirs[i].name)+'</option>';}}var html='<div class="modal" style="width:600px"><h2>'+(isEdit?"Edit Deal":"New Deal")+'</h2><div class="form-group"><label>Title *</label><input id="dlTitle" placeholder="e.g. 50% Off Dinner"></div><div class="form-group"><label>Description</label><textarea id="dlDesc" rows="2" placeholder="Describe this offer..."></textarea></div><div class="form-group" style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><div><label>Original Price</label><input id="dlOp" placeholder="19.99"></div><div><label>Deal Price</label><input id="dlDp" placeholder="9.99"></div></div><div class="form-group" style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><div><label>Discount %</label><input id="dlPct" type="number" placeholder="50"></div><div><label>Currency</label><input id="dlCur" value="USD"></div></div><div class="form-group"><label>Directory *</label><select id="dlDir">'+dirOpts+'</select></div><div class="form-group"><label>Business ID *</label><input id="dlBiz" placeholder="UUID of the business"></div><div class="form-group" style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><div><label>Start Date</label><input id="dlStart" type="datetime-local"></div><div><label>End Date</label><input id="dlEnd" type="datetime-local"></div></div><div class="form-group"><label>Redemption Limit</label><input id="dlLimit" type="number" placeholder="Unlimited"></div><div class="form-group"><label>Status</label><select id="dlStatus"><option value="active">Active</option><option value="scheduled">Scheduled</option><option value="expired">Expired</option><option value="sold_out">Sold Out</option></select></div><div class="form-group"><label>Deal Type</label><select id="dlType"><option value="coupon">Coupon</option><option value="deal">Deal</option><option value="promotion">Promotion</option></select></div><div class="form-group"><label>Coupon Code (optional)</label><input id="dlCode" placeholder="e.g. SUMMER50"></div><div class="form-group"><label>Terms & Conditions</label><textarea id="dlTerms" rows="2" placeholder="Fine print..."></textarea></div><div class="form-group"><label><input type="checkbox" id="dlFeatured"> Featured Deal</label></div><div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal('dealModal')">Cancel</button><button class="btn btn-primary" id="dlSaveBtn" onclick="saveDeal('+(isEdit?did:"null")+')">'+(isEdit?"Save Changes":"Create Deal")+'</button></div></div>';ov.innerHTML=html;document.body.appendChild(ov);if(isEdit){fetchDealForEdit(did);}}
async function fetchDealForEdit(did){try{var d=await g("/api/v1/deals/"+did);document.getElementById("dlTitle").value=d.title||"";document.getElementById("dlDesc").value=d.description||"";document.getElementById("dlOp").value=d.original_price||"";document.getElementById("dlDp").value=d.deal_price||"";document.getElementById("dlPct").value=d.discount_percent||"";document.getElementById("dlCur").value=d.currency||"USD";if(d.directory_id)document.getElementById("dlDir").value=d.directory_id;document.getElementById("dlBiz").value=d.business_id;if(d.start_date)document.getElementById("dlStart").value=d.start_date.substring(0,16);if(d.end_date)document.getElementById("dlEnd").value=d.end_date.substring(0,16);document.getElementById("dlLimit").value=d.redemption_limit||"";if(d.status)document.getElementById("dlStatus").value=d.status;if(d.deal_type)document.getElementById("dlType").value=d.deal_type;document.getElementById("dlCode").value=d.coupon_code||"";document.getElementById("dlTerms").value=d.terms||"";document.getElementById("dlFeatured").checked=d.featured===true;}catch(e){toast("Failed to load deal: "+e.message,"error");}}
async function saveDeal(did){var title=document.getElementById("dlTitle").value.trim();var dir=document.getElementById("dlDir").value;var biz=document.getElementById("dlBiz").value.trim();if(!title||!dir||!biz){toast("Title, directory, and business ID are required","error");return;}var body={title:title,description:document.getElementById("dlDesc").value.trim()||null,original_price:document.getElementById("dlOp").value.trim()||null,deal_price:document.getElementById("dlDp").value.trim()||null,discount_percent:parseInt(document.getElementById("dlPct").value)||null,currency:document.getElementById("dlCur").value.trim()||"USD",directory_id:dir,business_id:biz,start_date:document.getElementById("dlStart").value?new Date(document.getElementById("dlStart").value).toISOString():null,end_date:document.getElementById("dlEnd").value?new Date(document.getElementById("dlEnd").value).toISOString():null,redemption_limit:parseInt(document.getElementById("dlLimit").value)||null,status:document.getElementById("dlStatus").value,deal_type:document.getElementById("dlType").value,coupon_code:document.getElementById("dlCode").value.trim()||null,terms:document.getElementById("dlTerms").value.trim()||null,featured:document.getElementById("dlFeatured").checked};try{if(did){await pu("/api/v1/deals/"+did,body);}else{await po("/api/v1/deals",body);}toast("Deal saved!");closeModal("dealModal");loadDeals();}catch(e){toast(e.message,"error");}}
async function editDeal(did){showDealModal(did);}
async function deleteDeal(did){if(!confirm("Delete this deal?"))return;try{await dl("/api/v1/deals/"+did);toast("Deal deleted");loadDeals();}catch(e){toast(e.message,"error");}}
async function claimDeal(did){try{var d=await po("/api/v1/deals/"+did+"/claim");toast("Deal claimed! Redemptions: "+d.redemption_count,"success");loadDeals();}catch(e){toast(e.message,"error");}}

var PGS=["dashboard","directories","listings","search","categories","reviews","blog","legals","deals","analytics","submissions","seo","apikeys","settings"];
if(PGS.indexOf(CP)===-1)CP="dashboard";
function esc(s){if(!s)return"";return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");}
var WT={
dashboard:{i:"📊",t:"Dashboard",x:"Welcome to Multi-Directory! Monitor your directory network, track listings, searches, and user engagement at a glance."},
directories:{i:"📁",t:"Directories",x:"Create and manage local business directories. Each directory can target a specific city, industry, or niche."},
listings:{i:"📋",t:"Listings",x:"Add business listings with name, address, phone, website, hours, and category. Import from Google Places or Yelp."},
search:{i:"🔍",t:"Search",x:"Test search functionality. Search across all directories for businesses, categories, and locations."},
categories:{i:"🏷",t:"Categories",x:"Organize listings with categories. Create hierarchical category structures for easy browsing."},
apikeys:{i:"🔑",t:"API Keys",x:"Generate API keys for programmatic access. Enable third-party integrations and data imports."},
settings:{i:"⚙️",t:"Settings",x:"Configure your directory platform, manage tenant settings, and update your password."},
blog:{i:"📝",t:"Blog",x:"Publish SEO-optimized blog posts per directory. Write articles about local businesses, events, guides. Each post is indexed by search engines."},
legals:{i:"⚖️",t:"Legal Pages",x:"Create and manage legal pages for your directories. Privacy policy, terms of service, disclaimers, and more. Pages appear in the footer of directory landing pages."},deals:{i:"🎟️",t:"Deals",x:"Create and manage deals, coupons, and promotions. Set up Groupon-style offers with discounts, redemption limits, and scheduling for your directory businesses."},analytics:{i:"📊",t:"Analytics",x:"Track page views, listing views, clicks, and deal claims. View summary stats, per-directory breakdowns, and recent events across your directory network.",seo:{i:"🔍",t:"SEO",x:"Manage SEO meta tags, sitemap configuration, and search engine optimization for your directories and listings."}};
var TEMPLATES=[{slug:"default",name:"Teal (Default)",colors:{primary:"#0d9488",secondary:"#14b8a6",accent:"#0f766e",background:"#f0fdfa",text:"#0f172a"},emoji:"\ud83c\udfe0"},{slug:"farm",name:"Farm and Ag",colors:{primary:"#2d6a4f",secondary:"#40916c",accent:"#d4a373",background:"#fafaf5",text:"#1a1a2e"},emoji:"\ud83c\udf3e"},{slug:"medical",name:"Medical and Health",colors:{primary:"#2563eb",secondary:"#3b82f6",accent:"#1d4ed8",background:"#eff6ff",text:"#0f172a"},emoji:"\ud83c\udfe5"},{slug:"real-estate",name:"Real Estate",colors:{primary:"#1e3a5f",secondary:"#1e4d8c",accent:"#cbd5e1",background:"#f8fafc",text:"#0f172a"},emoji:"\ud83c\udfe2"},{slug:"restaurant",name:"Restaurants",colors:{primary:"#d97706",secondary:"#f59e0b",accent:"#92400e",background:"#fffbeb",text:"#0f172a"},emoji:"\ud83c\udf7d\ufe0f"},{slug:"service",name:"Services",colors:{primary:"#7c3aed",secondary:"#8b5cf6",accent:"#5b21b6",background:"#f5f3ff",text:"#0f172a"},emoji:"\ud83d\udd27"}];function getTemplate(s){for(var i=0;i<TEMPLATES.length;i++){if(TEMPLATES[i].slug===s)return TEMPLATES[i];}return TEMPLATES[0];}function slugify(s){return s.toLowerCase().replace(/[^a-z0-9]+/g,"-").replace(/^-|-$/g,"");}function showWalkthrough(p){var w=WT[p];if(!w)return;var k="ws_dir_"+p+"_dismissed";if(localStorage.getItem(k))return;document.getElementById("walkthroughIcon").textContent=w.i;document.getElementById("walkthroughTitle").textContent=w.t;document.getElementById("walkthroughText").textContent=w.x;var d=document.getElementById("walkthroughDots"),h="";for(var i=0;i<PGS.length;i++)h+="<span"+(PGS[i]===p?" class=\"active\"":"")+"></span>";d.innerHTML=h;document.getElementById("walkthroughOverlay").style.display="flex";}
function dismissWalkthrough(){localStorage.setItem("ws_dir_"+CP+"_dismissed","true");closeWalkthrough();}
function closeWalkthrough(){document.getElementById("walkthroughOverlay").style.display="none";}
function toast(m,t){if(!t)t="info";var c=document.getElementById("toastContainer"),el=document.createElement("div");el.className="toast "+t;el.textContent=m;c.appendChild(el);setTimeout(function(){el.style.opacity="0";el.style.transition="opacity .3s";setTimeout(function(){el.remove()},300);},3000);}
async function api(mth,path,body){var opts={method:mth,headers:{"Content-Type":"application/json"}};if(token)opts.headers["Authorization"]="Bearer "+token;if(body)opts.body=JSON.stringify(body);var res=await fetch(path,opts);if(!res.ok){var e=res.statusText;try{var d=await res.json();e=d.detail||d.message||e}catch(e1){}throw new Error(e)}return res.json();}
function g(p){return api("GET",p);}function po(p,b){return api("POST",p,b);}function pu(p,b){return api("PUT",p,b);}function dl(p){return api("DELETE",p);}
function closeModal(id){var m=document.getElementById(id);if(m)m.remove();}
function spn(){var d=document.createElement("div");d.style.cssText="text-align:center;padding:40px";d.innerHTML="<span class=\"spinner-teal\"></span>";return d;}
var TTL={dashboard:"Dashboard",directories:"Directories",listings:"Listings",search:"Search",categories:"Categories",seo:"SEO",apikeys:"API Keys",settings:"Settings",blog:"Blog",legals:"Legal Pages",reviews:"Reviews",reviews:"Reviews",deals:"Deals",analytics:"Analytics",submissions:"Submissions"};
var ICO={dashboard:"📊",directories:"📁",listings:"📋",search:"🔍",categories:"🏷",seo:"🔍",apikeys:"🔑",settings:"⚙️",blog:"📝",legals:"⚖️",reviews:"⭐",reviews:"⭐",deals:"🎟️",analytics:"📊",submissions:"📋"};
function navigate(p){CP=p;history.pushState({page:p},"",location.pathname+"#"+p);render();}
window.addEventListener("popstate",function(e){CP=(e.state&&e.state.page)||"dashboard";render();});
function renderLogin(){document.getElementById("helpIcon").style.display="none";document.getElementById("app").innerHTML=
'<div class="login-container"><div class="login-card"><h1>📊 Multi-Directory</h1><p class="tagline">Find Local Businesses</p><div class="error" id="loginError"></div><div class="form-group"><label>Email</label><input type="email" id="loginEmail" placeholder="admin@swiftsoftware.com" autocomplete="email"></div><div class="form-group"><label>Password</label><input type="password" id="loginPassword" placeholder="Enter password" autocomplete="current-password"></div><button class="btn btn-primary btn-full" id="loginBtn">Sign In</button></div></div>';
document.getElementById("loginBtn").onclick=doLogin;
document.getElementById("loginEmail").addEventListener("keydown",function(e){if(e.key==="Enter")doLogin();});
document.getElementById("loginPassword").addEventListener("keydown",function(e){if(e.key==="Enter")doLogin();});
document.getElementById("loginEmail").focus();}
async function doLogin(){var email=document.getElementById("loginEmail").value.trim(),pw=document.getElementById("loginPassword").value,err=document.getElementById("loginError"),btn=document.getElementById("loginBtn");if(!email||!pw){err.textContent="Please enter email and password";err.style.display="block";return;}err.style.display="none";btn.disabled=true;btn.innerHTML=
'<span class="spinner"></span> Signing in...';
try{var data=await po("/api/v1/auth/login",{email:email,password:pw});token=data.access_token;user=data.user||{email:email};localStorage.setItem("ws_dir_token",token);localStorage.setItem("ws_dir_user",JSON.stringify(user));render();}catch(e){err.textContent=e.message||"Login failed";err.style.display="block";btn.disabled=false;btn.textContent="Sign In";}}
function logout(){token="";user=null;localStorage.removeItem("ws_dir_token");localStorage.removeItem("ws_dir_user");render();}

async function loadAnalytics(){var el=document.getElementById("pageContent"),pa=document.getElementById("pageActions");pa.innerHTML="";el.innerHTML='<div class="empty-state" id="analyticsLoading"><div class="icon">\U0001f4ca</div><h3>Loading Analytics...</h3></div>';try{var s=await g("/api/v1/analytics/summary");var el=document.getElementById("pageContent");if(!el)return;var h='<div class="stat-grid"><div class="stat-card"><div class="icon">\U0001f4ca</div><span class="num">'+(s.total_page_views||0)+'</span><div class="label">Page Views</div></div><div class="stat-card"><div class="icon">\U0001f4de</div><span class="num">'+(s.total_phone_clicks||0)+'</span><div class="label">Phone Clicks</div></div><div class="stat-card"><div class="icon">\U0001f310</div><span class="num">'+(s.total_website_clicks||0)+'</span><div class="label">Website Clicks</div></div><div class="stat-card"><div class="icon">\U0001f39f\ufe0f</div><span class="num">'+(s.total_deal_claims||0)+'</span><div class="label">Deal Claims</div></div></div>';h+='<div class="card" style="margin-bottom:16px"><h3 style="margin-bottom:12px">Daily Activity (Last 14 Days)</h3><div style="display:flex;align-items:flex-end;gap:4px;height:120px;padding:8px 0" id="dailyChart">';if(s.daily_counts&&s.daily_counts.length>0){var mx=1;for(var i=0;i<s.daily_counts.length;i++){if(s.daily_counts[i].count>mx)mx=s.daily_counts[i].count;}for(var i=0;i<s.daily_counts.length;i++){var dc=s.daily_counts[i];var pct=(dc.count/mx)*100;h+='<div style="flex:1;display:flex;flex-direction:column;align-items:center;height:100%;justify-content:flex-end"><div style="width:100%;background:var(--teal);border-radius:4px 4px 0 0;height:'+Math.max(pct,2)+'%;min-height:2px;transition:height .3s" title="'+dc.date+': '+dc.count+'"></div><span style="font-size:.6rem;color:var(--text-secondary);margin-top:4px;writing-mode:vertical-lr;text-orientation:mixed">'+dc.date.substring(5)+'</span></div>';}}else{h+='<p style="color:var(--text-secondary);font-size:.85rem">No data yet</p>';}h+='</div></div>';h+='<div class="card" style="margin-bottom:16px"><h3 style="margin-bottom:12px">Top Listings</h3>';if(s.top_listings&&s.top_listings.length>0){h+='<div class="table-wrap"><table><thead><tr><th>Entity</th><th>Type</th><th>Views</th></tr></thead><tbody>';for(var i=0;i<s.top_listings.length;i++){var tl=s.top_listings[i];h+='<tr><td>'+(tl.entity_id||"-")+'</td><td>'+(tl.entity_type||"-")+'</td><td>'+tl.count+'</td></tr>';}h+='</tbody></table></div>';}else{h+='<p style="color:var(--text-secondary);font-size:.85rem">No top listings yet</p>';}h+='</div>';h+='<div class="card"><h3 style="margin-bottom:12px">Recent Events</h3>';try{var evts=await g("/api/v1/analytics/events?limit=20");if(evts.data&&evts.data.length>0){h+='<div class="table-wrap"><table><thead><tr><th>Time</th><th>Event</th><th>Entity</th><th>Entity ID</th></tr></thead><tbody>';for(var i=0;i<evts.data.length;i++){var e=evts.data[i];h+='<tr><td style="white-space:nowrap">'+((e.created_at||"").substring(0,16)||"-")+'</td><td><span class="badge active">'+esc(e.event_type)+'</span></td><td>'+esc(e.entity_type||"-")+'</td><td style="font-family:monospace;font-size:.75rem">'+(e.entity_id?e.entity_id.substring(0,8):"-")+'</td></tr>';}h+='</tbody></table></div>';}else{h+='<p style="color:var(--text-secondary);font-size:.85rem">No recent events</p>';}}catch(e2){h+='<p style="color:var(--danger);font-size:.85rem">Error loading events</p>';}h+='</div>';el.innerHTML=h;}catch(e){if(el)el.innerHTML='<div class="empty-state"><div class="icon">\u26a0\ufe0f</div><h3>Could not load analytics</h3><p>'+esc(e.message)+'</p></div>';}}

function render(){if(!token||!user){renderLogin();return;}renderApp();}
function renderApp(){var app=document.getElementById("app");document.getElementById("helpIcon").style.display="flex";var nav="";for(var i=0;i<PGS.length;i++)nav+=
'<a class="'+(PGS[i]===CP?"active":"")+'" onclick="navigate(\''+PGS[i]+'\')"><span class="icon">'+ICO[PGS[i]]+'</span> '+TTL[PGS[i]]+'</a>';
app.innerHTML='<div class="sidebar"><div class="sidebar-brand"><h2>📊 Multi-Directory</h2><p>Find Local Businesses</p></div><nav class="sidebar-nav">'+nav+'</nav><div class="sidebar-footer"><div class="user-email">'+esc(user.email)+'</div><a onclick="logout()">🚪 Sign Out</a></div></div><div class="main" id="mainArea"><div class="main-header"><h1 id="pageTitle">'+(TTL[CP]||"Dashboard")+'</h1><div class="main-header-actions" id="pageActions"></div></div><div class="main-content" id="pageContent"></div></div>';
document.getElementById("pageTitle").textContent=TTL[CP]||"Dashboard";
document.getElementById("pageActions").innerHTML="";
document.getElementById("pageContent").innerHTML="";
switch(CP){case"dashboard":loadDashboard();break;case"directories":loadDirectories();break;case"listings":loadListings();break;case"search":loadSearch();break;case"categories":loadCategories();break;case"reviews":loadReviews();break;case"reviews":loadReviews();break;case"apikeys":loadApiKeys();break;case"settings":loadSettings();break;case"blog":loadBlog();break;case"legals":loadLegals();break;case"analytics":loadAnalytics();break;case"deals":loadDeals();break;case"submissions":loadSubmissions();break;case"seo":loadSeo();break;}
setTimeout(function(){showWalkthrough(CP)},100);}
async function loadDashboard(){var el=document.getElementById("pageContent");el.appendChild(spn());try{var s=await g("/api/v1/dashboard/stats");
el.innerHTML=
'<div class="stat-grid"><div class="stat-card"><div class="icon">📊</div><span class="num">'+(s.total_directories||0)+'</span><div class="label">Total Directories</div></div><div class="stat-card"><div class="icon">📋</div>
<span class="num">'+(s.total_listings||0)+'</span><div class="label">Total Listings</div></div><div class="stat-card"><div class="icon">👥</div>
<span class="num">'+(s.active_users||0)+'</span><div class="label">Active Users</div></div><div class="stat-card"><div class="icon">🔍</div>
<span class="num">'+(s.searches_today||0)+'</span><div class="label">Searches Today</div></div></div>';
}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">⚠️</div><h3>Could not load stats</h3><p>'+esc(e.message)+'</p></div>';}}
async function loadDirectories(){var el=document.getElementById("pageContent"),pa=document.getElementById("pageActions");pa.innerHTML='<button class="btn btn-primary btn-sm" onclick="showDirModal(null)">+ Add Directory</button>';el.appendChild(spn());try{var dirs=await g("/api/v1/directories");g_sync=dirs;if(!dirs.length){el.innerHTML='<div class="empty-state"><div class="icon">\U0001F4C1</div><h3>No Directories Yet</h3><p>Click Add Directory to create your first one.</p></div>';return;}var h="";for(var i=0;i<dirs.length;i++){var d=dirs[i];var tc=d.template_config||{};var ts=tc.slug||d.template||"default";var tm=getTemplate(ts);var cc=tm?tm.colors:TEMPLATES[0].colors;var loc=d.city||tc.city||"";var connIds=tc.connected_directories||d.connected_directory_ids||[];h+='<div class="card" style="border-left:4px solid '+(cc?cc.primary:TEMPLATES[0].colors.primary)+'">'+'<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">'+'<span class="template-badge" style="background:'+(cc?cc.primary:TEMPLATES[0].colors.primary)+';color:#fff;padding:2px 8px;border-radius:4px;font-size:.7rem;font-weight:600">'+(tm?tm.emoji:"\U0001F3E0")+" "+(tm?tm.name:'Default')+'</span>'+(loc?'<span style="background:#e2e8f0;color:#334155;padding:2px 8px;border-radius:4px;font-size:.7rem">\U0001F4CC '+esc(loc)+"</span>":'')+(connIds.length>0?'<span style="background:#1e3a5f;color:#bfdbfe;padding:2px 8px;border-radius:4px;font-size:.7rem">\U0001F517 '+connIds.length+' connected</span>':'')+'</div>'+'<h3 style="color:var(--teal);margin-bottom:4px;font-size:1rem">'+esc(d.name)+'</h3>'+'<p style="font-size:.8rem;color:var(--text-secondary);margin-bottom:4px">Slug: '+esc(d.slug)+'</p>'+'<p style="font-size:.8rem;color:var(--text-secondary);margin-bottom:8px">'+esc(d.description||'')+'</p>'+'<div class="flex">'+'<button class="btn btn-secondary btn-sm" onclick="showDirModal('+d.id+')">\u270F\uFE0F Edit</button>'+'<button class="btn btn-secondary btn-sm" onclick="showCloneModal('+d.id+')">\U0001F4CB Clone</button>'+'<button class="btn btn-secondary btn-sm" onclick="showConnModal('+d.id+')">\U0001F517 Connect</button>'+'<button class="btn btn-danger btn-sm" onclick="deleteDir('+d.id+')">\U0001F5D1\uFE0F</button>'+'</div></div>';}el.innerHTML='<div class="card-grid">'+h+"</div>";}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">\u26A0\uFE0F</div><h3>Error</h3><p>'+esc(e.message)+"</p></div>";}}function showDirModal(dirId){if(dirId===null||dirId===undefined||dirId==="null"){showDirAddForm();return;}
g("/api/v1/directories").then(function(dirs){var dir=null;for(var i=0;i<dirs.length;i++){if(dirs[i].id===dirId){dir=dirs[i];break;}}if(!dir){toast("Directory not found","error");return;}
var tc=dir.template_config||{};var curTemp=tc.slug||dir.template||"default";
var ov=document.createElement("div");ov.className="modal-overlay";ov.id="dirModal";
var tempOpts="";for(var t=0;t<TEMPLATES.length;t++){tempOpts+='<option value="'+TEMPLATES[t].slug+'"'+(TEMPLATES[t].slug===curTemp?" selected":"")+'>'+TEMPLATES[t].emoji+" "+TEMPLATES[t].name+"</option>";}
var tm=getTemplate(curTemp);var cc=tm?tm.colors:TEMPLATES[0].colors;
var connOpts="";for(var j=0;j<dirs.length;j++){if(dirs[j].id===dirId)continue;var isConn=false;var connIds=tc.connected_directories||dir.connected_directory_ids||[];for(var k=0;k<connIds.length;k++){if(connIds[k]===dirs[j].id){isConn=true;break;}}connOpts+='<label style="display:flex;align-items:center;gap:6px;padding:4px 0;font-size:.85rem"><input type="checkbox" class="conn-checkbox" value="'+dirs[j].id+'"'+(isConn?" checked":"")+">"+esc(dirs[j].name)+" ("+esc(dirs[j].slug)+")</label>";}
var loc=tc.city||dir.city||"";
ov.innerHTML='<div class="modal" style="width:600px"><h2>Edit Directory</h2>'+
'<div class="form-group"><label>Name</label><input id="dirName" value="'+esc(dir.name)+'"></div>'+
'<div class="form-group"><label>Slug</label><input id="dirSlug" value="'+esc(dir.slug)+'"></div>'+
'<div class="form-group"><label>Description</label><textarea id="dirDesc" rows="2">'+esc(dir.description||"")+'</textarea></div>'+
'<div class="form-group"><label>City / Location</label><input id="dirCity" value="'+esc(loc)+'" placeholder="e.g. Miami, FL"></div>'+
'<div class="form-group"><label>Template</label><select id="dirTemplate" onchange="previewTemplate()">'+tempOpts+'</select></div>'+
'<div class="form-group" style="border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:12px"><label style="font-weight:600;margin-bottom:8px;display:block">\U0001F3A8 Template Colors</label><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">'+
'<div><label style="font-size:.75rem;display:block;margin-bottom:2px">Primary</label><input type="color" id="tcPrimary" value="'+(tc.colors?tc.colors.primary||cc.primary:cc.primary)+'" class="tc-color" style="width:100%;height:32px;border:1px solid var(--border);border-radius:6px;cursor:pointer"></div>'+
'<div><label style="font-size:.75rem;display:block;margin-bottom:2px">Secondary</label><input type="color" id="tcSecondary" value="'+(tc.colors?tc.colors.secondary||cc.secondary:cc.secondary)+'" class="tc-color" style="width:100%;height:32px;border:1px solid var(--border);border-radius:6px;cursor:pointer"></div>'+
'<div><label style="font-size:.75rem;display:block;margin-bottom:2px">Accent</label><input type="color" id="tcAccent" value="'+(tc.colors?tc.colors.accent||cc.accent:cc.accent)+'" class="tc-color" style="width:100%;height:32px;border:1px solid var(--border);border-radius:6px;cursor:pointer"></div>'+
'<div><label style="font-size:.75rem;display:block;margin-bottom:2px">Background</label><input type="color" id="tcBg" value="'+(tc.colors?tc.colors.background||cc.background:cc.background)+'" class="tc-color" style="width:100%;height:32px;border:1px solid var(--border);border-radius:6px;cursor:pointer"></div>'+
'<div><label style="font-size:.75rem;display:block;margin-bottom:2px">Text</label><input type="color" id="tcText" value="'+(tc.colors?tc.colors.text||cc.text:cc.text)+'" class="tc-color" style="width:100%;height:32px;border:1px solid var(--border);border-radius:6px;cursor:pointer"></div>'+
'</div><div style="margin-top:8px;display:flex;align-items:center;gap:8px"><div id="colorPreview" style="flex:1;height:40px;border-radius:8px;background:linear-gradient(135deg,'+(tc.colors?tc.colors.primary||cc.primary:cc.primary)+' 0%,'+(tc.colors?tc.colors.secondary||cc.secondary:cc.secondary)+' 100%);border:1px solid var(--border)"></div><button class="btn btn-secondary btn-sm" onclick="resetTemplateColors()">Reset</button></div></div>'+
'<div class="form-group" style="border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:12px"><label style="font-weight:600;margin-bottom:8px;display:block">\U0001F517 Connected Directories (Sister Cities)</label><div style="max-height:120px;overflow-y:auto">'+(connOpts||"<p style='font-size:.8rem;color:var(--text-secondary)'>No other directories to link.</p>")+"</div></div>"+
'<div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal(\'dirModal\')">Cancel</button><button class="btn btn-primary" onclick="saveDir(\''+dir.id+'\')">Save Changes</button></div></div>';
document.body.appendChild(ov);document.getElementById("dirName").focus();});}

function showDirAddForm(){var ov=document.createElement("div");ov.className="modal-overlay";ov.id="dirModal";
var tempOpts="";for(var t=0;t<TEMPLATES.length;t++){tempOpts+='<option value="'+TEMPLATES[t].slug+'">'+TEMPLATES[t].emoji+" "+TEMPLATES[t].name+"</option>";}
ov.innerHTML='<div class="modal" style="width:600px"><h2>Add Directory</h2>'+
'<div class="form-group"><label>Name</label><input id="dirName" placeholder="e.g. Miami Businesses"></div>'+
'<div class="form-group"><label>Slug</label><input id="dirSlug" placeholder="e.g. miami"></div>'+
'<div class="form-group"><label>Description</label><textarea id="dirDesc" rows="2"></textarea></div>'+
'<div class="form-group"><label>City / Location</label><input id="dirCity" placeholder="e.g. Miami, FL"></div>'+
'<div class="form-group"><label>Template</label><select id="dirTemplate" onchange="previewTemplate()">'+tempOpts+'</select></div>'+
'<div class="form-group" style="border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:12px"><label style="font-weight:600;margin-bottom:8px;display:block">\U0001F3A8 Template Colors</label><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">'+
'<div><label style="font-size:.75rem;display:block;margin-bottom:2px">Primary</label><input type="color" id="tcPrimary" value="#0d9488" class="tc-color" style="width:100%;height:32px;border:1px solid var(--border);border-radius:6px;cursor:pointer"></div>'+
'<div><label style="font-size:.75rem;display:block;margin-bottom:2px">Secondary</label><input type="color" id="tcSecondary" value="#14b8a6" class="tc-color" style="width:100%;height:32px;border:1px solid var(--border);border-radius:6px;cursor:pointer"></div>'+
'<div><label style="font-size:.75rem;display:block;margin-bottom:2px">Accent</label><input type="color" id="tcAccent" value="#0f766e" class="tc-color" style="width:100%;height:32px;border:1px solid var(--border);border-radius:6px;cursor:pointer"></div>'+
'<div><label style="font-size:.75rem;display:block;margin-bottom:2px">Background</label><input type="color" id="tcBg" value="#f0fdfa" class="tc-color" style="width:100%;height:32px;border:1px solid var(--border);border-radius:6px;cursor:pointer"></div>'+
'<div><label style="font-size:.75rem;display:block;margin-bottom:2px">Text</label><input type="color" id="tcText" value="#0f172a" class="tc-color" style="width:100%;height:32px;border:1px solid var(--border);border-radius:6px;cursor:pointer"></div>'+
'</div><div style="margin-top:8px;display:flex;align-items:center;gap:8px"><div id="colorPreview" style="flex:1;height:40px;border-radius:8px;background:linear-gradient(135deg,#0d9488 0%,#14b8a6 100%);border:1px solid var(--border)"></div><button class="btn btn-secondary btn-sm" onclick="resetTemplateColors()">Reset</button></div></div>'+
'<div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal(\'dirModal\')">Cancel</button><button class="btn btn-primary" onclick="saveDir(null)">Create</button></div></div>';
document.body.appendChild(ov);document.getElementById("dirName").focus();}

function previewTemplate(){var sel=document.getElementById("dirTemplate");var tm=getTemplate(sel.value);if(!tm)return;var cc=tm.colors;document.getElementById("tcPrimary").value=cc.primary;document.getElementById("tcSecondary").value=cc.secondary;document.getElementById("tcAccent").value=cc.accent;document.getElementById("tcBg").value=cc.background;document.getElementById("tcText").value=cc.text;document.getElementById("colorPreview").style.background="linear-gradient(135deg,"+cc.primary+" 0%,"+cc.secondary+" 100%)";}
function resetTemplateColors(){var sel=document.getElementById("dirTemplate");var tm=getTemplate(sel.value);if(!tm)return;previewTemplate();}

async function saveDir(id){var nm=document.getElementById("dirName").value.trim(),sl=document.getElementById("dirSlug").value.trim(),de=document.getElementById("dirDesc").value.trim(),ct=document.getElementById("dirCity").value.trim(),tpl=document.getElementById("dirTemplate").value;
var tc={slug:tpl,colors:{primary:document.getElementById("tcPrimary").value,secondary:document.getElementById("tcSecondary").value,accent:document.getElementById("tcAccent").value,background:document.getElementById("tcBg").value,text:document.getElementById("tcText").value},city:ct,connected_directories:[]};var checks=document.querySelectorAll(".conn-checkbox:checked");for(var i=0;i<checks.length;i++){tc.connected_directories.push(checks[i].value);}
if(!nm||!sl){toast("Name and slug are required","error");return;}
var body={name:nm,slug:sl,description:de,template:tpl,template_config:tc};if(ct)body.city=ct;
try{if(id&&id!=="null")await pu("/api/v1/directories/"+id,body);else await po("/api/v1/directories",body);
toast("Directory "+(id&&id!=="null"?"updated":"created")+"!");closeModal("dirModal");loadDirectories();}catch(e){toast(e.message,"error");}}
async function deleteDir(id){if(!confirm("Delete this directory?"))return;try{await dl("/api/v1/directories/"+id);toast("Directory deleted","success");loadDirectories();}catch(e){toast(e.message,"error");}}
async function loadListings(){var el=document.getElementById("pageContent"),pa=document.getElementById("pageActions");pa.innerHTML='<button class="btn btn-primary btn-sm" onclick="showListingModal(null)">+ Add Listing</button>';el.appendChild(spn());try{var ls=await g("/api/v1/listings");if(!ls.length){el.innerHTML='<div class="empty-state"><div class="icon">\U0001f4cb</div><h3>No Listings Yet</h3><p>Click &quot;Add Listing&quot; to add your first business.</p></div>';return;}var h="";for(var i=0;i<ls.length;i++){var l=ls[i];h+='<div class="card"><h3 style="color:var(--teal);margin-bottom:6px">'+esc(l.name)+"</h3>";if(l.category)h+='<span class="badge category" style="margin-bottom:6px;display:inline-block">'+esc(l.category)+"</span>";h+='<p style="font-size:.8rem;color:var(--text-secondary);margin-top:4px">'+esc(l.address||"")+(l.phone?" \u00b7 "+esc(l.phone):"")+"</p>";if(l.website)h+='<p style="font-size:.8rem"><a href="'+esc(l.website)+'" target="_blank">'+esc(l.website)+"</a></p>";h+='<div class="flex mt-2"><button class="btn btn-secondary btn-sm" onclick="editListing('+l.id+')">\u270f\ufe0f</button><button class="btn btn-danger btn-sm" onclick="deleteListing('+l.id+')">\U0001f5d1\ufe0f</button></div></div>";}el.innerHTML='<div class="card-grid">'+h+"</div>";}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">\u26a0\ufe0f</div><h3>Error</h3><p>'+esc(e.message)+"</p></div>";}}
function showListingModal(listing){var ie=!!listing;var ov=document.createElement("div");ov.className="modal-overlay";ov.id="listingModal";ov.innerHTML='<div class="modal"><h2>'+(ie?"Edit":"Add")+' Listing</h2><div class="form-group"><label>Name *</label><input id="lisName" value="'+esc(listing?listing.name:"")+'"></div><div class="form-group"><label>Address</label><input id="lisAddress" value="'+esc(listing?listing.address:"")+'"></div><div class="form-group"><label>Phone</label><input id="lisPhone" value="'+esc(listing?listing.phone:"")+'"></div><div class="form-group"><label>Website</label><input id="lisWebsite" value="'+esc(listing?listing.website:"")+'"></div><div class="form-group"><label>Category</label><input id="lisCategory" value="'+esc(listing?listing.category:"")+'"></div><div class="form-group"><label>Directory ID</label><input id="lisDirId" type="number" value="'+(listing?listing.directory_id||"":"")+'"></div><div class="form-group"><label>Hours</label><input id="lisHours" value="'+esc(listing?listing.hours:"")+'"></div><div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal(&#x27;listingModal&#x27;)">Cancel</button><button class="btn btn-primary" onclick="saveListing('+(listing?listing.id:"null")+')">'+(ie?"Save Changes":"Create")+'</button></div></div>';document.body.appendChild(ov);document.getElementById("lisName").focus();}
async function saveListing(id){var body={name:document.getElementById("lisName").value.trim(),address:document.getElementById("lisAddress").value.trim(),phone:document.getElementById("lisPhone").value.trim(),website:document.getElementById("lisWebsite").value.trim(),category:document.getElementById("lisCategory").value.trim(),hours:document.getElementById("lisHours").value.trim(),directory_id:parseInt(document.getElementById("lisDirId").value)||null};if(!body.name){toast("Name is required","error");return;}try{if(id)await pu("/api/v1/listings/"+id,body);else await po("/api/v1/listings",body);toast("Listing "+(id?"updated":"created")+"!","success");closeModal("listingModal");loadListings();}catch(e){toast(e.message,"error");}}
function editListing(id){g("/api/v1/listings").then(function(ls){for(var i=0;i<ls.length;i++){if(ls[i].id===id){showListingModal(ls[i]);return;}}}).catch(function(e){toast(e.message,"error");});}
async function deleteListing(id){if(!confirm("Delete this listing?"))return;try{await dl("/api/v1/listings/"+id);toast("Listing deleted","success");loadListings();}catch(e){toast(e.message,"error");}}
function loadSearch(){var el=document.getElementById("pageContent");el.innerHTML='<div class="search-box"><input type="text" id="searchInput" placeholder="Search businesses, categories, locations..." onkeydown="if(event.key===\'Enter\')doSearch()"><button class="btn btn-primary" onclick="doSearch()">\U0001f50d Search</button></div><div id="searchResults"></div>';document.getElementById("searchInput").focus();}
async function doSearch(){var q=document.getElementById("searchInput").value.trim();var el=document.getElementById("searchResults");if(!q){el.innerHTML='<div class="empty-state"><div class="icon">\U0001f50d</div><h3>Enter a search term</h3><p>Search across all directories for businesses and categories.</p></div>';return;}el.innerHTML='<div style="text-align:center;padding:20px"><span class="spinner-teal"></span></div>';try{var results=await g("/api/v1/search?q="+encodeURIComponent(q));if(!results.length){el.innerHTML='<div class="empty-state"><div class="icon">\U0001f5e8</div><h3>No results found</h3><p>Try a different search term.</p></div>';return;}var h="<h3 style=\"margin-bottom:12px;font-size:1rem;color:var(--text-secondary)\">"+results.length+" result"+(results.length===1?"":"s")+'</h3><div class="card-grid">';for(var i=0;i<results.length;i++){var r=results[i];h+='<div class="card"><h3 style="color:var(--teal);margin-bottom:6px">'+esc(r.name)+"</h3>";if(r.category)h+='<span class="badge category">'+esc(r.category)+"</span>";h+='<p style="font-size:.8rem;color:var(--text-secondary)">'+esc(r.address||"")+"</p></div>";}el.innerHTML=h+"</div>";}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">\u26a0\ufe0f</div><h3>Error</h3><p>'+esc(e.message)+"</p></div>";}}
async function loadCategories(){var el=document.getElementById("pageContent"),pa=document.getElementById("pageActions");pa.innerHTML='<button class="btn btn-primary btn-sm" onclick="showCatModal(null)">+ Add Category</button>';el.appendChild(spn());try{var cats=await g("/api/v1/categories");if(!cats.length){el.innerHTML='<div class="empty-state"><div class="icon">\U0001f3f7</div><h3>No Categories Yet</h3><p>Click &quot;Add Category&quot; to create your first one.</p></div>';return;}var h="";for(var i=0;i<cats.length;i++){var cat=cats[i];h+='<div class="card"><h3 style="color:var(--teal);margin-bottom:8px">'+esc(cat.name)+"</h3>";if(cat.description)h+='<p style="font-size:.85rem;color:var(--text-secondary)">'+esc(cat.description)+"</p>";h+='<div class="flex mt-2"><button class="btn btn-secondary btn-sm" onclick="editCat('+cat.id+')">\u270f\ufe0f</button><button class="btn btn-danger btn-sm" onclick="deleteCat('+cat.id+')">\U0001f5d1\ufe0f</button></div></div>";}el.innerHTML='<div class="card-grid">'+h+"</div>";}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">\u26a0\ufe0f</div><h3>Error</h3><p>'+esc(e.message)+"</p></div>";}}
function showCatModal(cat){var ie=!!cat;var ov=document.createElement("div");ov.className="modal-overlay";ov.id="catModal";ov.innerHTML='<div class="modal"><h2>'+(ie?"Edit":"Add")+' Category</h2><div class="form-group"><label>Name</label><input id="catName" value="'+esc(cat?cat.name:"")+'"></div><div class="form-group"><label>Description</label><textarea id="catDesc" rows="3">'+esc(cat?cat.description:"")+'</textarea></div><div class="form-group"><label>Parent ID</label><input id="catParent" type="number" value="'+(cat?cat.parent_id||"":"")+'"></div><div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal(&#x27;catModal&#x27;)">Cancel</button><button class="btn btn-primary" onclick="saveCat('+(cat?cat.id:"null")+')">'+(ie?"Save Changes":"Create")+'</button></div></div>';document.body.appendChild(ov);document.getElementById("catName").focus();}
async function saveCat(id){var nm=document.getElementById("catName").value.trim(),de=document.getElementById("catDesc").value.trim(),pi=parseInt(document.getElementById("catParent").value)||null;if(!nm){toast("Name is required","error");return;}try{if(id){await pu("/api/v1/categories/"+id,{name:nm,description:de,parent_id:pi});}else{await po("/api/v1/categories",{name:nm,description:de,parent_id:pi});}toast("Category "+(id?"updated":"created")+"!","success");closeModal("catModal");loadCategories();}catch(e){toast(e.message,"error");}}
function editCat(id){g("/api/v1/categories").then(function(cats){for(var i=0;i<cats.length;i++){if(cats[i].id===id){showCatModal(cats[i]);return;}}}).catch(function(e){toast(e.message,"error");});}
async function deleteCat(id){if(!confirm("Delete this category?"))return;try{await dl("/api/v1/categories/"+id);toast("Category deleted","success");loadCategories();}catch(e){toast(e.message,"error");}}
async function loadApiKeys(){var el=document.getElementById("pageContent"),pa=document.getElementById("pageActions");pa.innerHTML='<button class="btn btn-primary btn-sm" onclick="genApiKey()">+ Generate Key</button>';el.appendChild(spn());try{var keys=await g("/api/v1/api-keys");if(!keys.length){el.innerHTML='<div class="empty-state"><div class="icon">\U0001f511</div><h3>No API Keys Yet</h3><p>Generate an API key for programmatic access.</p></div>';return;}var h='<div class="table-wrap"><table><thead><tr><th>Name</th><th>Key</th><th>Status</th><th>Actions</th></tr></thead><tbody>';for(var i=0;i<keys.length;i++){var k=keys[i];h+='<tr><td>'+esc(k.name||"Unnamed")+'</td><td><span class="copy-key" onclick="navigator.clipboard.writeText(&#x27;'+esc(k.key)+"&#x27;);toast(&#x27;Copied!&#x27;,&#x27;success&#x27;)">"+esc(k.key.substring(0,16)+"...")+'</span></td><td><span class="badge '+(k.active===false?"key-revoked":"key-active")+'">'+(k.active===false?"Revoked":"Active")+'</span></td><td><button class="btn btn-danger btn-sm" onclick="revokeKey('+k.id+')">Revoke</button></td></tr>';}h+='</tbody></table></div>';el.innerHTML=h;}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">\u26a0\ufe0f</div><h3>Error</h3><p>'+esc(e.message)+"</p></div>";}}
async function genApiKey(){var name=prompt("Enter a name for this API key:");if(!name)return;try{var key=await po("/api/v1/api-keys",{name:name});toast("API key generated!","success");loadApiKeys();}catch(e){toast(e.message,"error");}}
async function revokeKey(id){if(!confirm("Revoke this API key?"))return;try{await dl("/api/v1/api-keys/"+id);toast("API key revoked","success");loadApiKeys();}catch(e){toast(e.message,"error");}}
async function loadSettings(){var el=document.getElementById("pageContent");el.innerHTML='<div style="text-align:center;padding:40px"><span class="spinner-teal"></span></div>';try{var s=await g("/api/v1/settings");el.innerHTML='<div style="max-width:600px"><h3 style="color:var(--teal);margin-bottom:16px">Tenant Settings</h3><div class="card" style="margin-bottom:16px"><div class="form-group"><label>Tenant Name</label><input id="setName" value="'+esc(s.name||"")+'"></div><div class="form-group"><label>Slug</label><input id="setSlug" value="'+esc(s.slug||"")+'"></div><button class="btn btn-primary" onclick="saveSettings()">Save Settings</button></div><div class="card"><h3 style="color:var(--teal);margin-bottom:12px">Change Password</h3><div class="form-group"><label>Current Password</label><input type="password" id="setCurPw"></div><div class="form-group"><label>New Password</label><input type="password" id="setNewPw"></div><button class="btn btn-primary" onclick="changePassword()">Update Password</button></div></div>';}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">\u26a0\ufe0f</div><h3>Error</h3><p>'+esc(e.message)+"</p></div>";}}
async function saveSettings(){var name=document.getElementById("setName").value.trim(),slug=document.getElementById("setSlug").value.trim();if(!name||!slug){toast("Name and slug are required","error");return;}try{await pu("/api/v1/settings",{name:name,slug:slug});toast("Settings saved!","success");}catch(e){toast(e.message,"error");}}
async function changePassword(){var cur=document.getElementById("setCurPw").value,nw=document.getElementById("setNewPw").value;if(!cur||!nw){toast("Both password fields are required","error");return;}try{await pu("/api/v1/settings/password",{current_password:cur,new_password:nw});toast("Password updated!","success");document.getElementById("setCurPw").value="";document.getElementById("setNewPw").value="";}catch(e){toast(e.message,"error");}}

async function loadSeo(){var el=document.getElementById("pageContent"),pa=document.getElementById("pageActions");pa.innerHTML='<button class="btn btn-primary btn-sm" onclick="regenerateSitemap()">Regenerate Sitemap</button> <a href="/api/v1/sitemap.xml" target="_blank" class="btn btn-secondary btn-sm">View sitemap.xml</a>';el.appendChild(spn());try{var dirs=await g("/api/v1/directories");if(!dirs.length){el.innerHTML='<div class="empty-state"><div class="icon">🔍</div><h3>No Directories</h3><p>Create directories first to manage SEO.</p></div>';return;}var h='<h3 style="margin-bottom:16px">Directory SEO Config</h3><div class="card-grid">';for(var i=0;i<dirs.length;i++){var d=dirs[i];h+='<div class="card"><h4 style="color:var(--teal);margin-bottom:8px">'+esc(d.name)+'</h4><p style="font-size:.8rem;color:var(--text-secondary);margin-bottom:12px">'+esc(d.slug)+'</p><div class="flex"><button class="btn btn-sm btn-secondary" onclick="showSitemapConfigModal(\''+d.id+'\')">Sitemap Config</button><button class="btn btn-sm btn-secondary" onclick="showSeoMetaModal(\'directory\',\''+d.id+'\')">Edit SEO Meta</button></div></div>';}h+='</div>';h+='<h3 style="margin-top:24px;margin-bottom:12px">Page Type SEO</h3><div class="card-grid">';var pages=[{t:"homepage",l:"Homepage",id:"homepage"},{t:"listing",l:"Listing Pages",id:"all"},{t:"blog",l:"Blog Posts",id:"all"}];for(var i=0;i<pages.length;i++){h+='<div class="card"><h4>'+esc(pages[i].l)+'</h4><p style="font-size:.8rem;color:var(--text-secondary);margin-bottom:8px">Set default SEO meta for '+esc(pages[i].l).toLowerCase()+'</p><button class="btn btn-sm btn-secondary" onclick="showSeoMetaModal(\''+pages[i].t+'\',\''+pages[i].id+'\')">Edit</button></div>';}h+='</div>';el.innerHTML=h;}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">⚠️</div><h3>Error</h3><p>'+esc(e.message)+'</p></div>';}}

function showSeoMetaModal(pageType,pageId){var ov=document.createElement("div");ov.className="modal-overlay";ov.id="seoMetaModal";ov.innerHTML='<div class="modal" style="width:560px"><h2>SEO Meta: '+esc(pageType)+'/'+esc(pageId)+'</h2><div class="form-group"><label>Meta Title</label><input id="seoTitle" placeholder="Page title for search results"></div><div class="form-group"><label>Meta Description</label><textarea id="seoDesc" rows="2" placeholder="Meta description"></textarea></div><div class="form-group"><label>Keywords (comma separated)</label><input id="seoKeywords" placeholder="keyword1, keyword2, keyword3"></div><div class="form-group"><label>OG Image URL</label><input id="seoOgImage" placeholder="https://..."></div><div class="form-group"><label>OG Title</label><input id="seoOgTitle" placeholder="Open Graph title"></div><div class="form-group"><label>OG Description</label><textarea id="seoOgDesc" rows="2" placeholder="Open Graph description"></textarea></div><div class="form-group"><label>Schema Type</label><select id="seoSchema"><option value="">None</option><option value="LocalBusiness">LocalBusiness</option><option value="Restaurant">Restaurant</option><option value="MedicalBusiness">MedicalBusiness</option><option value="RealEstateAgent">RealEstateAgent</option><option value="AutomotiveBusiness">AutomotiveBusiness</option><option value="ProfessionalService">ProfessionalService</option><option value="Store">Store</option><option value="Organization">Organization</option></select></div><div class="form-group"><label><input type="checkbox" id="seoClear" onclick="clearSeoForm()"> Clear & use defaults</label></div><div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal(\'seoMetaModal\')">Cancel</button><button class="btn btn-primary" onclick="saveSeoMeta(\''+pageType+'\',\''+pageId+'\')">Save</button></div></div>';document.body.appendChild(ov);loadSeoMetaForEdit(pageType,pageId);}

async function loadSeoMetaForEdit(pageType,pageId){try{var meta=await g("/api/v1/seo/"+pageType+"/"+pageId);if(meta&&meta.title){document.getElementById("seoTitle").value=meta.title||"";document.getElementById("seoDesc").value=meta.description||"";document.getElementById("seoKeywords").value=meta.keywords||"";document.getElementById("seoOgImage").value=meta.og_image||"";document.getElementById("seoOgTitle").value=meta.og_title||"";document.getElementById("seoOgDesc").value=meta.og_description||"";if(meta.schema_type)document.getElementById("seoSchema").value=meta.schema_type;}}catch(e){toast("Could not load SEO meta: "+e.message,"error");}}

function clearSeoForm(){if(confirm("Clear SEO meta fields?")){document.getElementById("seoTitle").value="";document.getElementById("seoDesc").value="";document.getElementById("seoKeywords").value="";document.getElementById("seoOgImage").value="";document.getElementById("seoOgTitle").value="";document.getElementById("seoOgDesc").value="";}}

async function saveSeoMeta(pageType,pageId){var body={title:document.getElementById("seoTitle").value.trim()||null,description:document.getElementById("seoDesc").value.trim()||null,keywords:document.getElementById("seoKeywords").value.trim()||null,og_image:document.getElementById("seoOgImage").value.trim()||null,og_title:document.getElementById("seoOgTitle").value.trim()||null,og_description:document.getElementById("seoOgDesc").value.trim()||null,schema_type:document.getElementById("seoSchema").value||null};try{await pu("/api/v1/seo/"+pageType+"/"+pageId,body);toast("SEO meta saved!");closeModal("seoMetaModal");}catch(e){toast(e.message,"error");}}

function showSitemapConfigModal(dirId){var ov=document.createElement("div");ov.className="modal-overlay";ov.id="sitemapModal";ov.innerHTML='<div class="modal"><h2>Sitemap Configuration</h2><div class="form-group"><label><input type="checkbox" id="scAuto" checked> Auto-generate sitemap</label></div><div class="form-group"><label>Priority (0.1 - 1.0)</label><input type="range" id="scPriority" min="0.1" max="1.0" step="0.1" value="0.5" oninput="document.getElementById(\'scPriorityVal\').textContent=this.value"><span id="scPriorityVal" style="margin-left:8px;font-weight:600">0.5</span></div><div class="form-group"><label>Change Frequency</label><select id="scFreq"><option value="always">Always</option><option value="hourly">Hourly</option><option value="daily">Daily</option><option value="weekly" selected>Weekly</option><option value="monthly">Monthly</option><option value="yearly">Yearly</option><option value="never">Never</option></select></div><div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal(\'sitemapModal\')">Cancel</button><button class="btn btn-primary" onclick="saveSitemapConfig(\''+dirId+'\')">Save</button></div></div>';document.body.appendChild(ov);loadSitemapConfig(dirId);}

async function loadSitemapConfig(dirId){try{var cfg=await g("/api/v1/seo/sitemap-config/"+dirId);if(cfg&&cfg.auto_generate!==undefined){document.getElementById("scAuto").checked=cfg.auto_generate!==false;if(cfg.priority){document.getElementById("scPriority").value=cfg.priority;document.getElementById("scPriorityVal").textContent=cfg.priority;}if(cfg.change_freq)document.getElementById("scFreq").value=cfg.change_freq;}}catch(e){toast("Could not load config: "+e.message,"error");}}

async function saveSitemapConfig(dirId){var body={auto_generate:document.getElementById("scAuto").checked,priority:parseFloat(document.getElementById("scPriority").value)||0.5,change_freq:document.getElementById("scFreq").value};try{await pu("/api/v1/seo/sitemap-config/"+dirId,body);toast("Sitemap config saved!");closeModal("sitemapModal");loadSeo();}catch(e){toast(e.message,"error");}}

async function regenerateSitemap(){try{var r=await po("/api/v1/seo/regenerate-sitemap");toast("Sitemap regenerated for "+r.directories_updated+" directories!");}catch(e){toast(e.message,"error");}}

render();
})();


async function loadReviews(){var el=document.getElementById("pageContent"),pa=document.getElementById("pageActions");pa.innerHTML='<button class="btn btn-primary btn-sm" onclick="showNewReviewModal()">+ New Review</button>';el.appendChild(spn());try{var r=await g("/api/v1/reviews");if(!r.data.length){el.innerHTML='<div class="empty-state"><div class="icon">\u2b50</div><h3>No Reviews Yet</h3><p>Reviews appear here when customers submit them. Approve or reject pending reviews.</p></div>';return;}var h='<div class="card-grid">';for(var i=0;i<r.data.length;i++){var v=r.data[i];var st=v.status||"pending";var bg=st==="pending"?"background:#fef9c3":st==="approved"?"background:#dcfce7":"background:#fef2f2";var stars="";for(var s=0;s<v.rating;s++)stars+="\u2b50";h+='<div class="card" style="'+bg+';border-left:4px solid '+(st==="pending"?"#eab308":st==="approved"?"#22c55e":"#ef4444")+'"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px"><strong>'+esc(v.reviewer_name||"Anonymous")+'</strong><span class="badge '+(st==="approved"?"active":st==="rejected"?"inactive":"")+'">'+st+'</span></div><div style="margin-bottom:4px">'+stars+'</div><div style="font-size:.85rem;margin-bottom:4px"><em>'+esc(v.title||"")+'</em></div><p style="font-size:.8rem;color:var(--text-secondary);margin-bottom:8px">'+esc((v.content||"").substring(0,200))+'</p><div style="font-size:.75rem;color:var(--text-secondary);margin-bottom:8px"><span>Business: '+esc(v.business_id||"")+'</span></div><div class="flex">'+'<button class="btn btn-sm btn-secondary" onclick="showReviewModal(''+v.id+'')">View</button>'+'<button class="btn btn-sm btn-primary" onclick="approveReview(''+v.id+'')" '+(st==="approved"?"disabled":"")+'>Approve</button>'+'<button class="btn btn-sm btn-danger" onclick="rejectReview(''+v.id+'')" '+(st==="rejected"?"disabled":"")+'>Reject</button>'+'<button class="btn btn-sm btn-danger" onclick="deleteReview(''+v.id+'')">Delete</button>'+'</div></div>';}h+='</div>';el.innerHTML=h;}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">\u26a0\ufe0f</div><h3>Error</h3><p>'+esc(e.message)+"</p></div>";}}

async function showReviewModal(id){try{var v=await g("/api/v1/reviews/"+id);var ov=document.createElement("div");ov.className="modal-overlay";ov.id="reviewModal";var stars="";for(var s=0;s<v.rating;s++)stars+="\u2b50";var st=v.status||"pending";var stColor=st==="pending"?"var(--warning)":st==="approved"?"var(--success)":"var(--danger)";ov.innerHTML='<div class="modal" style="width:500px"><h2>Review Details</h2><div style="margin-bottom:16px"><div style="display:flex;justify-content:space-between;align-items:center"><h3 style="font-size:1.1rem">'+esc(v.reviewer_name||"Anonymous")+'</h3><span style="color:'+stColor+';font-weight:600">'+st.toUpperCase()+'</span></div><div style="margin:8px 0">'+stars+'</div><div style="font-size:.95rem;font-weight:600;margin-bottom:4px">'+esc(v.title||"")+'</div><div style="font-size:.9rem;margin-bottom:12px;line-height:1.5;color:var(--text-secondary)">'+esc(v.content||"")+'</div><div style="font-size:.8rem;color:var(--text-secondary)">'+(v.reviewer_email?'<div>Email: '+esc(v.reviewer_email)+'</div>':'')+'<div>Business ID: '+esc(v.business_id||"")+'</div><div>Date: '+(v.created_at||"").substring(0,19)+'</div><div>Source: '+esc(v.source||"direct")+'</div>'+(v.source_url?'<div>Source URL: '+esc(v.source_url)+'</div>':'')+'</div></div><div class="modal-actions">'+'<button class="btn btn-secondary" onclick="closeModal('reviewModal')">Close</button>'+'<button class="btn btn-primary" onclick="approveReview(''+id+'');closeModal('reviewModal')" '+(st==="approved"?"disabled":"")+'>Approve</button>'+'<button class="btn btn-danger" onclick="rejectReview(''+id+'');closeModal('reviewModal')" '+(st==="rejected"?"disabled":"")+'>Reject</button>'+'</div></div>';document.body.appendChild(ov);}catch(e){toast(e.message,"error");}}

function showNewReviewModal(){var ov=document.createElement("div");ov.className="modal-overlay";ov.id="newReviewModal";ov.innerHTML='<div class="modal" style="width:500px"><h2>\u2b50 Submit a Review</h2><p style="font-size:.85rem;color:var(--text-secondary);margin-bottom:16px">Share your experience with this business. No account required.</p><div class="form-group"><label>Your Name *</label><input id="rrName" placeholder="John Doe"></div><div class="form-group"><label>Your Email</label><input id="rrEmail" type="email" placeholder="john@example.com"></div><div class="form-group"><label>Business ID *</label><input id="rrBizId" placeholder="Paste the business UUID"></div><div class="form-group"><label>Rating *</label><div style="display:flex;gap:4px;font-size:1.5rem;cursor:pointer">';for(var s=1;s<=5;s++)ov.innerHTML+='<span id="rrStar'+s+'" onclick="setRating('+s+')" style="color:var(--border);transition:color .2s">\u2b50</span>';ov.innerHTML+='<input type="hidden" id="rrRating" value="0"></div></div><div class="form-group"><label>Title</label><input id="rrTitle" placeholder="Summary of your experience"></div><div class="form-group"><label>Review</label><textarea id="rrContent" rows="4" placeholder="Tell others about your experience..."></textarea></div><div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal('newReviewModal')">Cancel</button><button class="btn btn-primary" onclick="submitReview()">Submit Review</button></div></div>';document.body.appendChild(ov);document.getElementById("rrName").focus();}

function setRating(n){document.getElementById("rrRating").value=n;for(var s=1;s<=5;s++){var el=document.getElementById("rrStar"+s);if(el)el.style.color=s<=n?"#f59e0b":"var(--border)";}}

async function submitReview(){var name=document.getElementById("rrName").value.trim();var bizId=document.getElementById("rrBizId").value.trim();var rating=parseInt(document.getElementById("rrRating").value);if(!name||!bizId||!rating){toast("Name, Business ID, and Rating are required","error");return;}var body={business_id:bizId,rating:rating,reviewer_name:name,reviewer_email:document.getElementById("rrEmail").value.trim()||null,title:document.getElementById("rrTitle").value.trim()||null,content:document.getElementById("rrContent").value.trim()||null};try{await po("/api/v1/reviews",body);toast("Review submitted! It will appear after moderation.","success");closeModal("newReviewModal");if(typeof loadReviews==="function")loadReviews();}catch(e){toast(e.message,"error");}}

async function approveReview(id){try{var v=await po("/api/v1/reviews/"+id+"/approve");toast("Review approved!","success");loadReviews();}catch(e){toast(e.message,"error");}}

async function rejectReview(id){try{var v=await po("/api/v1/reviews/"+id+"/reject");toast("Review rejected","info");loadReviews();}catch(e){toast(e.message,"error");}}

async function deleteReview(id){if(!confirm("Delete this review?"))return;try{await dl("/api/v1/reviews/"+id);toast("Review deleted","success");loadReviews();}catch(e){toast(e.message,"error");}}

async function loadReviews(){var el=document.getElementById("pageContent"),pa=document.getElementById("pageActions");pa.innerHTML='<button class="btn btn-primary btn-sm" onclick="showNewReviewModal()">+ New Review</button>';el.appendChild(spn());try{var r=await g("/api/v1/reviews");if(!r.data.length){el.innerHTML='<div class="empty-state"><div class="icon">\u2b50</div><h3>No Reviews Yet</h3><p>Reviews appear here when customers submit them. Approve or reject pending reviews.</p></div>';return;}var h='<div class="card-grid">';for(var i=0;i<r.data.length;i++){var v=r.data[i];var st=v.status||"pending";var bg=st==="pending"?"background:#fef9c3":st==="approved"?"background:#dcfce7":"background:#fef2f2";var stars="";for(var s=0;s<v.rating;s++)stars+="\u2b50";h+='<div class="card" style="'+bg+';border-left:4px solid '+(st==="pending"?"#eab308":st==="approved"?"#22c55e":"#ef4444")+'"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px"><strong>'+esc(v.reviewer_name||"Anonymous")+'</strong><span class="badge '+(st==="approved"?"active":st==="rejected"?"inactive":"")+'">'+st+'</span></div><div style="margin-bottom:4px">'+stars+'</div><div style="font-size:.85rem;margin-bottom:4px"><em>'+esc(v.title||"")+'</em></div><p style="font-size:.8rem;color:var(--text-secondary);margin-bottom:8px">'+esc((v.content||"").substring(0,200))+'</p><div style="font-size:.75rem;color:var(--text-secondary);margin-bottom:8px"><span>Business: '+esc(v.business_id||"")+'</span></div><div class="flex">'+'<button class="btn btn-sm btn-secondary" onclick="showReviewModal(''+v.id+'')">View</button>'+'<button class="btn btn-sm btn-primary" onclick="approveReview(''+v.id+'')" '+(st==="approved"?"disabled":"")+'>Approve</button>'+'<button class="btn btn-sm btn-danger" onclick="rejectReview(''+v.id+'')" '+(st==="rejected"?"disabled":"")+'>Reject</button>'+'<button class="btn btn-sm btn-danger" onclick="deleteReview(''+v.id+'')">Delete</button>'+'</div></div>';}h+='</div>';el.innerHTML=h;}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">\u26a0\ufe0f</div><h3>Error</h3><p>'+esc(e.message)+"</p></div>";}}

async function showReviewModal(id){try{var v=await g("/api/v1/reviews/"+id);var ov=document.createElement("div");ov.className="modal-overlay";ov.id="reviewModal";var stars="";for(var s=0;s<v.rating;s++)stars+="\u2b50";var st=v.status||"pending";var stColor=st==="pending"?"var(--warning)":st==="approved"?"var(--success)":"var(--danger)";ov.innerHTML='<div class="modal" style="width:500px"><h2>Review Details</h2><div style="margin-bottom:16px"><div style="display:flex;justify-content:space-between;align-items:center"><h3 style="font-size:1.1rem">'+esc(v.reviewer_name||"Anonymous")+'</h3><span style="color:'+stColor+';font-weight:600">'+st.toUpperCase()+'</span></div><div style="margin:8px 0">'+stars+'</div><div style="font-size:.95rem;font-weight:600;margin-bottom:4px">'+esc(v.title||"")+'</div><div style="font-size:.9rem;margin-bottom:12px;line-height:1.5;color:var(--text-secondary)">'+esc(v.content||"")+'</div><div style="font-size:.8rem;color:var(--text-secondary)">'+(v.reviewer_email?'<div>Email: '+esc(v.reviewer_email)+'</div>':'')+'<div>Business ID: '+esc(v.business_id||"")+'</div><div>Date: '+(v.created_at||"").substring(0,19)+'</div><div>Source: '+esc(v.source||"direct")+'</div>'+(v.source_url?'<div>Source URL: '+esc(v.source_url)+'</div>':'')+'</div></div><div class="modal-actions">'+'<button class="btn btn-secondary" onclick="closeModal('reviewModal')">Close</button>'+'<button class="btn btn-primary" onclick="approveReview(''+id+'');closeModal('reviewModal')" '+(st==="approved"?"disabled":"")+'>Approve</button>'+'<button class="btn btn-danger" onclick="rejectReview(''+id+'');closeModal('reviewModal')" '+(st==="rejected"?"disabled":"")+'>Reject</button>'+'</div></div>';document.body.appendChild(ov);}catch(e){toast(e.message,"error");}}

function showNewReviewModal(){var ov=document.createElement("div");ov.className="modal-overlay";ov.id="newReviewModal";ov.innerHTML='<div class="modal" style="width:500px"><h2>\u2b50 Submit a Review</h2><p style="font-size:.85rem;color:var(--text-secondary);margin-bottom:16px">Share your experience with this business. No account required.</p><div class="form-group"><label>Your Name *</label><input id="rrName" placeholder="John Doe"></div><div class="form-group"><label>Your Email</label><input id="rrEmail" type="email" placeholder="john@example.com"></div><div class="form-group"><label>Business ID *</label><input id="rrBizId" placeholder="Paste the business UUID"></div><div class="form-group"><label>Rating *</label><div style="display:flex;gap:4px;font-size:1.5rem;cursor:pointer">';for(var s=1;s<=5;s++)ov.innerHTML+='<span id="rrStar'+s+'" onclick="setRating('+s+')" style="color:var(--border);transition:color .2s">\u2b50</span>';ov.innerHTML+='<input type="hidden" id="rrRating" value="0"></div></div><div class="form-group"><label>Title</label><input id="rrTitle" placeholder="Summary of your experience"></div><div class="form-group"><label>Review</label><textarea id="rrContent" rows="4" placeholder="Tell others about your experience..."></textarea></div><div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal('newReviewModal')">Cancel</button><button class="btn btn-primary" onclick="submitReview()">Submit Review</button></div></div>';document.body.appendChild(ov);document.getElementById("rrName").focus();}

function setRating(n){document.getElementById("rrRating").value=n;for(var s=1;s<=5;s++){var el=document.getElementById("rrStar"+s);if(el)el.style.color=s<=n?"#f59e0b":"var(--border)";}}

async function submitReview(){var name=document.getElementById("rrName").value.trim();var bizId=document.getElementById("rrBizId").value.trim();var rating=parseInt(document.getElementById("rrRating").value);if(!name||!bizId||!rating){toast("Name, Business ID, and Rating are required","error");return;}var body={business_id:bizId,rating:rating,reviewer_name:name,reviewer_email:document.getElementById("rrEmail").value.trim()||null,title:document.getElementById("rrTitle").value.trim()||null,content:document.getElementById("rrContent").value.trim()||null};try{await po("/api/v1/reviews",body);toast("Review submitted! It will appear after moderation.","success");closeModal("newReviewModal");if(typeof loadReviews==="function")loadReviews();}catch(e){toast(e.message,"error");}}

async function approveReview(id){try{var v=await po("/api/v1/reviews/"+id+"/approve");toast("Review approved!","success");loadReviews();}catch(e){toast(e.message,"error");}}

async function rejectReview(id){try{var v=await po("/api/v1/reviews/"+id+"/reject");toast("Review rejected","info");loadReviews();}catch(e){toast(e.message,"error");}}

async function deleteReview(id){if(!confirm("Delete this review?"))return;try{await dl("/api/v1/reviews/"+id);toast("Review deleted","success");loadReviews();}catch(e){toast(e.message,"error");}}
async function loadSubmissions(){var el=document.getElementById("pageContent"),pa=document.getElementById("pageActions");pa.innerHTML='<button class="btn btn-primary btn-sm" onclick="showNewSubmissionModal()">+ New Submission</button>';el.appendChild(spn());try{var subs=await g("/api/v1/submissions");el.innerHTML="";for(var s of subs){var statusClass=s.status==="approved"?"active":s.status==="rejected"?"inactive":"warning";el.innerHTML+='<div class="card" style="margin-bottom:12px;border-left:4px solid '+(s.status==="approved"?"var(--success)":s.status==="rejected"?"var(--danger)":"var(--warning)")+'"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px"><h4 style="font-size:1rem;color:var(--teal)">'+esc(s.business_name)+'</h4><span class="badge '+statusClass+'">'+esc(s.status||"pending")+'</span></div><div style="font-size:.8rem;color:var(--text-secondary);margin-bottom:6px"><span>Submitted: '+(s.created_at||"").substring(0,10)+'</span>'+(s.submitted_by?' <span>| By: '+esc(s.submitted_by)+'</span>':'')+'</div><div class="flex"><button class="btn btn-sm btn-secondary" onclick="showSubmissionModal(''+s.id+'')">View</button><button class="btn btn-sm btn-danger" onclick="deleteSubmission(''+s.id+'')">Delete</button></div></div>';}if(!subs.length)el.innerHTML='<div class="empty-state"><div class="icon">📋</div><h3>No Submissions Yet</h3><p>Public submissions will appear here for admin review.</p></div>';}catch(e){el.innerHTML='<div class="empty-state"><div class="icon">⚠️</div><h3>Error</h3><p>'+esc(e.message)+"</p></div>";}}
async function showSubmissionModal(id){try{var s=await g("/api/v1/submissions/"+id);var ov=document.createElement("div");ov.className="modal-overlay";ov.id="subModal";var html='<div class="modal" style="width:600px"><h2>Submission: '+esc(s.business_name)+'</h2><div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">';html+='<div><label style="font-size:.75rem;color:var(--text-secondary);display:block">Business Name</label><div style="font-weight:600">'+esc(s.business_name||"")+'</div></div>';html+='<div><label style="font-size:.75rem;color:var(--text-secondary);display:block">Category</label><div>'+esc(s.category||"-")+'</div></div>';html+='<div><label style="font-size:.75rem;color:var(--text-secondary);display:block">Address</label><div>'+esc(s.address||"-")+'</div></div>';html+='<div><label style="font-size:.75rem;color:var(--text-secondary);display:block">City</label><div>'+esc(s.city||"-")+'</div></div>';html+='<div><label style="font-size:.75rem;color:var(--text-secondary);display:block">State</label><div>'+esc(s.state||"-")+'</div></div>';html+='<div><label style="font-size:.75rem;color:var(--text-secondary);display:block">ZIP</label><div>'+esc(s.zip||"-")+'</div></div>';html+='<div><label style="font-size:.75rem;color:var(--text-secondary);display:block">Phone</label><div>'+esc(s.phone||"-")+'</div></div>';html+='<div><label style="font-size:.75rem;color:var(--text-secondary);display:block">Email</label><div>'+esc(s.email||"-")+'</div></div>';html+='<div style="grid-column:1/-1"><label style="font-size:.75rem;color:var(--text-secondary);display:block">Website</label><div>'+(s.website?'<a href="'+esc(s.website)+'" target="_blank">'+esc(s.website)+'</a>':"-")+'</div></div>';html+='<div style="grid-column:1/-1"><label style="font-size:.75rem;color:var(--text-secondary);display:block">Description</label><div>'+esc(s.description||"-")+'</div></div>';html+='<div><label style="font-size:.75rem;color:var(--text-secondary);display:block">Submitted By</label><div>'+esc(s.submitted_by||"-")+'</div></div>';html+='<div><label style="font-size:.75rem;color:var(--text-secondary);display:block">Submitter Email</label><div>'+esc(s.submitter_email||"-")+'</div></div>';html+='<div><label style="font-size:.75rem;color:var(--text-secondary);display:block">Status</label><div><span class="badge '+(s.status==="approved"?"active":s.status==="rejected"?"inactive":"warning")+'">'+esc(s.status||"pending")+'</span></div></div>';html+='<div style="grid-column:1/-1"><label style="font-size:.75rem;color:var(--text-secondary);display:block">Admin Notes</label><div>'+esc(s.admin_notes||"-")+'</div></div>';html+='</div><div class="modal-actions">';if(s.status!=="approved")html+='<button class="btn btn-primary" onclick="approveSubmission(''+s.id+'')">✓ Approve</button>';if(s.status!=="rejected")html+='<button class="btn btn-danger" onclick="rejectSubmission(''+s.id+'')">✗ Reject</button>';html+='<button class="btn btn-secondary" onclick="closeModal('subModal')">Close</button></div></div>';ov.innerHTML=html;document.body.appendChild(ov);}catch(e){toast("Failed to load submission: "+e.message,"error");}}
async function showNewSubmissionModal(){var ov=document.createElement("div");ov.className="modal-overlay";ov.id="newSubModal";var dirOpts='<option value="">Select directory (optional)</option>';var dirs=g_sync;for(var i=0;i<dirs.length;i++){dirOpts+='<option value="'+dirs[i].id+'">'+esc(dirs[i].name)+'</option>';}var html='<div class="modal" style="width:600px"><h2>📋 Submit Your Business</h2><p style="font-size:.85rem;color:var(--text-secondary);margin-bottom:16px">Fill out the form below to submit your business for review. Our team will review and approve it.</p><div class="form-group"><label>Business Name *</label><input id="subName" placeholder="Your business name"></div><div class="form-group"><label>Category</label><input id="subCategory" placeholder="e.g. Restaurant, Dentist, etc."></div><div class="form-group" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px"><div><label>Address</label><input id="subAddress" placeholder="Street address"></div><div><label>City</label><input id="subCity" placeholder="City"></div><div><label>State</label><input id="subState" placeholder="State"></div></div><div class="form-group" style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><div><label>ZIP</label><input id="subZip" placeholder="ZIP code"></div><div><label>Phone</label><input id="subPhone" placeholder="Phone number"></div></div><div class="form-group"><label>Email</label><input id="subEmail" type="email" placeholder="Email address"></div><div class="form-group"><label>Website</label><input id="subWebsite" placeholder="https://example.com"></div><div class="form-group"><label>Description</label><textarea id="subDesc" rows="3" placeholder="Tell us about your business..."></textarea></div><div class="form-group" style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><div><label>Your Name</label><input id="subByName" placeholder="Your name"></div><div><label>Your Email</label><input id="subByEmail" type="email" placeholder="Your email"></div></div><div class="form-group"><label>Directory</label><select id="subDir">'+dirOpts+'</select><div style="font-size:.75rem;color:var(--text-secondary);margin-top:2px">Select which directory this business belongs to (optional).</div></div><div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal('newSubModal')">Cancel</button><button class="btn btn-primary" onclick="saveNewSubmission()">Submit for Review</button></div></div>';ov.innerHTML=html;document.body.appendChild(ov);document.getElementById("subName").focus();}
async function saveNewSubmission(){var name=document.getElementById("subName").value.trim();if(!name){toast("Business name is required","error");return;}var body={business_name:name,category:document.getElementById("subCategory").value.trim()||null,address:document.getElementById("subAddress").value.trim()||null,city:document.getElementById("subCity").value.trim()||null,state:document.getElementById("subState").value.trim()||null,zip:document.getElementById("subZip").value.trim()||null,phone:document.getElementById("subPhone").value.trim()||null,email:document.getElementById("subEmail").value.trim()||null,website:document.getElementById("subWebsite").value.trim()||null,description:document.getElementById("subDesc").value.trim()||null,submitted_by:document.getElementById("subByName").value.trim()||null,submitter_email:document.getElementById("subByEmail").value.trim()||null,directory_id:document.getElementById("subDir").value||null};try{await po("/api/v1/submissions",body);toast("Business submitted for review! We will review it shortly.","success");closeModal("newSubModal");loadSubmissions();}catch(e){toast(e.message,"error");}}
async function approveSubmission(id){if(!confirm("Approve this submission? A business record will be created."))return;try{var r=await po("/api/v1/submissions/"+id+"/approve");toast("Submission approved! Business created.","success");closeModal("subModal");loadSubmissions();}catch(e){toast(e.message,"error");}}
async function rejectSubmission(id){var notes=prompt("Rejection notes (optional):");if(notes===null)return;try{await po("/api/v1/submissions/"+id+"/reject",{admin_notes:notes||null});toast("Submission rejected.","info");closeModal("subModal");loadSubmissions();}catch(e){toast(e.message,"error");}}
async function deleteSubmission(id){if(!confirm("Delete this submission?"))return;try{await dl("/api/v1/submissions/"+id);toast("Submission deleted","success");loadSubmissions();}catch(e){toast(e.message,"error");}}
</script>
</body>
</html>function showCloneModal(srcId){g("/api/v1/directories").then(function(dirs){var src=null;for(var i=0;i<dirs.length;i++){if(dirs[i].id===srcId){src=dirs[i];break;}}if(!src){toast("Source directory not found","error");return;}var ov=document.createElement("div");ov.className="modal-overlay";ov.id="cloneModal";
ov.innerHTML='<div class="modal"><h2>\U0001F4CB Clone Directory</h2><p style="font-size:.85rem;color:var(--text-secondary);margin-bottom:16px">Cloning: <strong>'+esc(src.name)+'</strong></p>'+
'<div class="form-group"><label>New Directory Name</label><input id="cloneName" oninput="autoSlug()" placeholder="e.g. Fort Lauderdale Businesses"></div>'+
'<div class="form-group"><label>Slug</label><input id="cloneSlug" placeholder="e.g. fort-lauderdale"></div>'+
'<div class="form-group"><label>City / Location</label><input id="cloneCity" placeholder="e.g. Fort Lauderdale, FL"></div>'+
'<div class="form-group" style="display:flex;align-items:center;gap:12px;padding:10px 0"><label style="margin:0;cursor:pointer;display:flex;align-items:center;gap:8px"><input type="checkbox" id="cloneListings"> Clone listings (businesses)?</label></div>'+
'<div class="form-group" style="display:flex;align-items:center;gap:12px;padding:10px 0"><label style="margin:0;cursor:pointer;display:flex;align-items:center;gap:8px"><input type="checkbox" id="cloneLinkParent" checked> Link as sister city?</label></div>'+
'<div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal(\'cloneModal\')">Cancel</button><button class="btn btn-primary" onclick="doClone(\''+src.id+'\')">\U0001F680 Clone Directory</button></div></div>';
document.body.appendChild(ov);document.getElementById("cloneName").focus();});}
function autoSlug(){var nm=document.getElementById("cloneName").value.trim();if(nm){document.getElementById("cloneSlug").value=slugify(nm);}}
async function doClone(srcId){var nm=document.getElementById("cloneName").value.trim(),sl=document.getElementById("cloneSlug").value.trim(),ct=document.getElementById("cloneCity").value.trim(),cloneLis=document.getElementById("cloneListings").checked,linkPar=document.getElementById("cloneLinkParent").checked;if(!nm||!sl){toast("Name and slug are required","error");return;}
try{var src=await g("/api/v1/directories/"+srcId);var tc=src.template_config||{};var body={name:nm,slug:sl,description:"Cloned from "+src.name,template:src.template||"default",template_config:tc};if(ct)body.city=ct;var newDir=await po("/api/v1/directories",body);if(linkPar){var srcConn=tc.connected_directories||[];srcConn.push(newDir.id);await pu("/api/v1/directories/"+srcId,{connected_directory_ids:srcConn});var newTc=body.template_config||{};newTc.connected_directories=[srcId];await pu("/api/v1/directories/"+newDir.id,{template_config:newTc});}if(cloneLis){var listings=await g("/api/v1/directories/"+src.slug+"/businesses");for(var i=0;i<listings.length;i++){var l=listings[i];await po("/api/v1/directories/"+newDir.slug+"/businesses",{name:l.name,description:l.description||"",address:l.address||"",city:l.city||"",state:l.state||"",zip:l.zip||"",phone:l.phone||"",email:l.email||"",website:l.website||"",latitude:l.latitude,longitude:l.longitude,category_id:l.category_id});}}toast("Directory cloned successfully!");closeModal("cloneModal");loadDirectories();}catch(e){toast(e.message,"error");}}

function showConnModal(dirId){g("/api/v1/directories").then(function(dirs){var dir=null;for(var i=0;i<dirs.length;i++){if(dirs[i].id===dirId){dir=dirs[i];break;}}if(!dir){toast("Directory not found","error");return;}var tc=dir.template_config||{};var connIds=tc.connected_directories||dir.connected_directory_ids||[];var ov=document.createElement("div");ov.className="modal-overlay";ov.id="connModal";var list="<h2>\U0001F517 Sister Cities: "+esc(dir.name)+"</h2><p style='font-size:.85rem;color:var(--text-secondary);margin-bottom:12px'>Link directories to create a network. Connected directories show as Nearby on each other's pages.</p><div style='margin-bottom:12px'>";var found=0;for(var i=0;i<dirs.length;i++){if(dirs[i].id===dirId||!dirs[i].slug)continue;var isConn=false;for(var k=0;k<connIds.length;k++){if(connIds[k]===dirs[i].id||(typeof connIds[k]==="object"&&connIds[k].id===dirs[i].id)){isConn=true;break;}}var dTc=dirs[i].template_config||{};var dLoc=dTc.city||dirs[i].city||"";list+='<div class="card" style="margin-bottom:8px;padding:12px;display:flex;align-items:center;justify-content:space-between"><div><strong>'+esc(dirs[i].name)+'</strong>'+(dLoc?' <span style="font-size:.8rem;color:var(--text-secondary)">\U0001F4CC '+esc(dLoc)+"</span>":"")+'<br><span style="font-size:.75rem;color:var(--text-secondary)">'+esc(dirs[i].slug)+"</span></div>"+'<button class="btn btn-sm '+(isConn?"btn-danger":"btn-primary")+'" onclick="toggleConn(\''+dirId+"','"+dirs[i].id+"','"+esc(dirs[i].name).replace(/'/g,"")+'\')">'+(isConn?"Disconnect":"Connect")+"</button></div>";found++;}list+=(found===0?"<p style='font-size:.85rem;color:var(--text-secondary)'>No other directories to connect.</p>":"")+"</div>";list+='<div class="modal-actions"><button class="btn btn-secondary" onclick="closeModal(\'connModal\')">Done</button></div>';ov.innerHTML='<div class="modal" style="width:500px">'+list+"</div>";document.body.appendChild(ov);});}
async function toggleConn(dirId,targetId,targetName){try{var dir=await g("/api/v1/directories/"+dirId);var tc=dir.template_config||{};var connIds=tc.connected_directories||dir.connected_directory_ids||[];var idx=connIds.indexOf(targetId);var connecting;if(idx>-1){connIds.splice(idx,1);connecting=false}else{connIds.push(targetId);connecting=true}tc.connected_directories=connIds;await pu("/api/v1/directories/"+dirId,{template_config:tc,connected_directory_ids:connIds});var td=await g("/api/v1/directories/"+targetId);var ttc=td.template_config||{};var tConn=ttc.connected_directories||td.connected_directory_ids||[];var tidx=tConn.indexOf(dirId);if(connecting&&tidx===-1){tConn.push(dirId)}else if(!connecting&&tidx>-1){tConn.splice(tidx,1)}ttc.connected_directories=tConn;await pu("/api/v1/directories/"+targetId,{template_config:ttc,connected_directory_ids:tConn});toast((connecting?"Connected to ":"Disconnected from ")+targetName);closeModal("connModal");showConnModal(dirId);}catch(e){toast(e.message,"error");}}

function editDir(id){showDirModal(id);}

