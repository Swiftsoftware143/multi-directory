<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>{{directory.name}} - Real Estate</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>:root{--primary:{{colors.primary}};--secondary:{{colors.secondary}};--accent:{{colors.accent}};--bg:{{colors.background}};--text:{{colors.text}};--heading:{{colors.heading}};--muted:{{colors.muted}};--border:{{colors.border}}}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:"Roboto",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#f8fafc;color:var(--text)}
h1,h2,h3,h4,h5,h6{font-family:"Inter",sans-serif}
.container{max-width:1100px;margin:0 auto;padding:0 20px}
.hero{background:linear-gradient(135deg,#1e293b,#334155);padding:50px 0;color:white;text-align:center}
.hero h1{font-size:2.2rem;color:white}
.hero p{color:white;opacity:.9}
.search-bar{display:flex;gap:10px;margin:25px 0;flex-wrap:wrap}
.search-bar input{flex:1;padding:10px;border:2px solid #e2e8f0;border-radius:8px}
.search-bar select{padding:10px;border:2px solid #e2e8f0;border-radius:8px}
.search-bar button{padding:10px 22px;background:var(--primary);color:white;border:none;border-radius:8px;cursor:pointer}
.properties{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:20px}
.p-card{background:white;border-radius:10px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.06)}
.p-card-img{height:160px;background:linear-gradient(135deg,#e2e8f0,#cbd5e1);display:flex;align-items:center;justify-content:center;font-size:2rem}
.p-card-body{padding:18px}
.p-card-body h3 a{color:#1e293b;text-decoration:none}
.p-card-body .price{font-size:1.3rem;font-weight:700;color:var(--primary);margin-bottom:6px}
.p-card-body .badge{display:inline-block;padding:3px 8px;border-radius:4px;font-size:.8rem;background:#dbeafe;color:#1e40af;margin-bottom:6px}
.empty{text-align:center;padding:50px;color:gray}
.footer{text-align:center;padding:30px;color:gray;font-size:.85rem;border-top:1px solid #e2e8f0;margin-top:30px}
</style></head><body>
<section class="hero"><div class="container"><h1>{{directory.name}}</h1><p>{{directory.description}}</p></div></section>
<div class="container">
<form class="search-bar" method="GET">
<input type="text" name="q" placeholder="Search..." value="{{query.q}}">
<select name="listing_type"><option value="">All</option><option value="sale">For Sale</option><option value="rent">For Rent</option></select>
<button type="submit">Search</button>
</form>
{{#if businesses}}<div class="properties">{{#each businesses}}<div class="p-card"><div class="p-card-img">&#127968;</div><div class="p-card-body"><span class="badge">{{meta.listing_type}}</span>{{#if meta.price}}<div class="price">{{meta.price}}</div>{{/if}}<h3><a href="/{{../directory.slug}}/{{slug}}">{{name}}</a></h3><p style="color:gray;font-size:.9rem">{{city}}, {{state}}</p>{{#if phone}}<p><a href="tel:{{phone}}" style="color:var(--primary)">Contact</a></p>{{/if}}</div></div>{{/each}}</div>{{else}}<div class="empty"><h3>No listings</h3></div>{{/if}}
</div>
<div class="footer"><p>&copy; {{directory.name}}</p></div>
</body></html>