<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>{{directory.name}} - Restaurants</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>:root{--primary:{{colors.primary}};--secondary:{{colors.secondary}};--accent:{{colors.accent}};--bg:{{colors.background}};--text:{{colors.text}};--heading:{{colors.heading}};--muted:{{colors.muted}};--border:{{colors.border}}}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:"Roboto",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#fef2f2;color:var(--text)}
h1,h2,h3,h4,h5,h6{font-family:"Inter",sans-serif}
.container{max-width:1100px;margin:0 auto;padding:0 20px}
.hero{background:linear-gradient(135deg,#dc2626,#ea580c);padding:50px 0;color:white;text-align:center}
.hero h1{font-size:2.2rem;color:white}
.hero p{color:white;opacity:.9}
.search-bar{display:flex;gap:10px;margin:25px 0;flex-wrap:wrap}
.search-bar input{flex:1;padding:10px;border:2px solid #fecaca;border-radius:8px}
.search-bar select{padding:10px;border:2px solid #fecaca;border-radius:8px}
.search-bar button{padding:10px 22px;background:#dc2626;color:white;border:none;border-radius:8px;cursor:pointer}
.restaurants{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:20px}
.r-card{background:white;border-radius:10px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.06)}
.r-card-img{height:120px;background:linear-gradient(135deg,#fca5a5,#fecaca);display:flex;align-items:center;justify-content:center;font-size:2rem}
.r-card-body{padding:16px}
.r-card-body h3 a{color:#991b1b;text-decoration:none}
.r-card-body .cuisine{display:inline-block;padding:3px 10px;border-radius:8px;font-size:.8rem;background:#fee2e2;color:#991b1b;margin-bottom:6px}
.r-card-body .rating{color:#f59e0b}
.actions{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap}
.actions a{padding:5px 12px;border-radius:6px;font-size:.85rem;text-decoration:none}
.empty{text-align:center;padding:50px;color:gray}
.footer{text-align:center;padding:30px;color:gray;font-size:.85rem;border-top:1px solid #fecaca;margin-top:30px}
</style></head><body>
<section class="hero"><div class="container"><h1>{{directory.name}}</h1><p>{{directory.description}}</p></div></section>
<div class="container">
<form class="search-bar" method="GET">
<input type="text" name="q" placeholder="Search..." value="{{query.q}}">
<select name="category"><option value="">All</option>{{#each categories}}<option value="{{slug}}">{{name}}</option>{{/each}}</select>
<button type="submit">Search</button>
</form>
{{#if businesses}}<div class="restaurants">{{#each businesses}}<div class="r-card"><div class="r-card-img">&#127869;</div><div class="r-card-body"><h3><a href="/{{../directory.slug}}/{{slug}}">{{name}}</a></h3>{{#if meta.cuisine}}<span class="cuisine">{{meta.cuisine}}</span>{{/if}}{{#if rating}}<div class="rating">&#9733; {{rating}} ({{review_count}})</div>{{/if}}<p style="color:gray;font-size:.9rem">{{city}}, {{state}}</p>{{#if meta.hours}}<p style="color:gray;font-size:.85rem">{{meta.hours}}</p>{{/if}}<div class="actions">{{#if meta.delivery}}<a href="#" style="background:#dcfce7;color:#166534">Delivery</a>{{/if}}{{#if meta.menu_url}}<a href="{{meta.menu_url}}" style="background:#dbeafe;color:#1e40af">Menu</a>{{/if}}{{#if phone}}<a href="tel:{{phone}}" style="background:#fee2e2;color:#991b1b">Call</a>{{/if}}</div></div></div>{{/each}}</div>{{else}}<div class="empty"><h3>No restaurants</h3></div>{{/if}}
</div>
<div class="footer"><p>&copy; {{directory.name}}</p></div>
</body></html>