<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>{{directory.name}} - Farmers Market</title>
<style>:root{--primary:{{colors.primary}};--secondary:{{colors.secondary}};--accent:{{colors.accent}};--bg:{{colors.background}};--text:{{colors.text}};--heading:{{colors.heading}};--muted:{{colors.muted}};--border:{{colors.border}}}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;background:#f0fdf4;color:var(--text)}
.container{max-width:1100px;margin:0 auto;padding:0 20px}
.hero{background:linear-gradient(135deg,#15803d,#16a34a);padding:50px 0;color:white;text-align:center}
.hero h1{font-size:2.2rem;color:white}
.hero p{color:white;opacity:.9}
.search-bar{display:flex;gap:10px;margin:25px 0;flex-wrap:wrap}
.search-bar input{flex:1;padding:10px;border:2px solid #bbf7d0;border-radius:8px}
.search-bar select{padding:10px;border:2px solid #bbf7d0;border-radius:8px}
.search-bar button{padding:10px 22px;background:#15803d;color:white;border:none;border-radius:8px;cursor:pointer}
.farms{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:20px}
.farm-card{background:white;border-radius:10px;overflow:hidden;border:1px solid #dcfce7}
.farm-card-img{height:120px;background:linear-gradient(135deg,#86efac,#bbf7d0);display:flex;align-items:center;justify-content:center;font-size:2rem}
.farm-card-body{padding:16px}
.farm-card-body h3 a{color:#166534;text-decoration:none}
.farm-card-body .season{display:inline-block;padding:3px 8px;border-radius:4px;font-size:.8rem;background:#dcfce7;color:#166534;margin-bottom:6px}
.farm-card-body .badge{display:inline-block;padding:3px 8px;border-radius:4px;font-size:.8rem;background:#fef3c7;color:#92400e;margin-bottom:6px}
.empty{text-align:center;padding:50px;color:gray}
.footer{text-align:center;padding:30px;color:gray;font-size:.85rem;border-top:1px solid #dcfce7;margin-top:30px}
</style></head><body>
<section class="hero"><div class="container"><h1>{{directory.name}}</h1><p>{{directory.description}}</p></div></section>
<div class="container">
<form class="search-bar" method="GET">
<input type="text" name="q" placeholder="Search farms..." value="{{query.q}}">
<select name="category"><option value="">All</option>{{#each categories}}<option value="{{slug}}">{{name}}</option>{{/each}}</select>
<button type="submit">Search</button>
</form>
{{#if businesses}}<div class="farms">{{#each businesses}}<div class="farm-card"><div class="farm-card-img">&#127793;</div><div class="farm-card-body"><h3><a href="/{{../directory.slug}}/{{slug}}">{{name}}</a></h3>{{#if meta.season}}<span class="season">{{meta.season}}</span>{{/if}}{{#if meta.produce}}<span class="badge">{{meta.produce}}</span>{{/if}}<p style="color:gray;font-size:.9rem">{{city}}, {{state}}</p>{{#if meta.hours}}<p style="color:gray;font-size:.85rem">{{meta.hours}}</p>{{/if}}<p>{{description}}</p>{{#if phone}}<p><a href="tel:{{phone}}" style="color:#15803d">Call {{phone}}</a></p>{{/if}}</div></div>{{/each}}</div>{{else}}<div class="empty"><h3>No farms found</h3></div>{{/if}}
</div>
<div class="footer"><p>&copy; {{directory.name}}</p></div>
</body></html>