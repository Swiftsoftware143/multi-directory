<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>{{directory.name}} - Medical</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>:root{--primary:{{colors.primary}};--secondary:{{colors.secondary}};--accent:{{colors.accent}};--bg:{{colors.background}};--text:{{colors.text}};--heading:{{colors.heading}};--muted:{{colors.muted}};--border:{{colors.border}}}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:"Roboto",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#f0f9ff;color:var(--text)}
h1,h2,h3,h4,h5,h6{font-family:"Inter",sans-serif}
.container{max-width:1100px;margin:0 auto;padding:0 20px}
.hero{background:linear-gradient(135deg,#0369a1,#0284c7);padding:50px 0;color:white;text-align:center}
.hero h1{font-size:2.2rem;color:white}
.hero p{color:white;opacity:.9}
.search-bar{display:flex;gap:10px;margin:25px 0;flex-wrap:wrap}
.search-bar input{flex:1;padding:10px;border:2px solid #bae6fd;border-radius:8px}
.search-bar select{padding:10px;border:2px solid #bae6fd;border-radius:8px}
.search-bar button{padding:10px 22px;background:#0369a1;color:white;border:none;border-radius:8px;cursor:pointer}
.providers{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:20px}
.provider{background:white;border-radius:10px;padding:18px;border:1px solid #e0f2fe}
.provider h3 a{color:#0369a1;text-decoration:none}
.provider .specialty{display:inline-block;background:#e0f2fe;color:#0369a1;padding:3px 10px;border-radius:8px;font-size:.8rem;margin-bottom:6px}
.provider .info{color:gray;font-size:.9rem}
.empty{text-align:center;padding:50px;color:gray}
.footer{text-align:center;padding:30px;color:gray;font-size:.85rem;border-top:1px solid #e0f2fe;margin-top:30px}
</style></head><body>
<section class="hero"><div class="container"><h1>{{directory.name}}</h1><p>{{directory.description}}</p></div></section>
<div class="container">
<form class="search-bar" method="GET">
<input type="text" name="q" placeholder="Search providers..." value="{{query.q}}">
<select name="category"><option value="">All</option>{{#each categories}}<option value="{{slug}}">{{name}}</option>{{/each}}</select>
<button type="submit">Search</button>
</form>
{{#if businesses}}<div class="providers">{{#each businesses}}<div class="provider"><h3><a href="/{{../directory.slug}}/{{slug}}">{{name}}</a></h3>{{#if meta.specialty}}<span class="specialty">{{meta.specialty}}</span>{{/if}}<div class="info"><p>{{city}}, {{state}}</p>{{description}}</div>{{#if phone}}<p><a href="tel:{{phone}}" style="color:#0369a1">Call {{phone}}</a></p>{{/if}}</div>{{/each}}</div>{{else}}<div class="empty"><h3>No providers</h3></div>{{/if}}
</div>
<div class="footer"><p>&copy; {{directory.name}}</p></div>
</body></html>